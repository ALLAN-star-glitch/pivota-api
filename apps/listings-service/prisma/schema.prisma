generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// =====================================================================
///                              CATEGORIES & HIERARCHY
/// =====================================================================
model Category {
  id            String   @id @default(cuid())
  externalId    String   @default(uuid()) @unique
  
  // NEW: Discriminator for which pillar this belongs to
  vertical      String   // e.g., "JOBS", "HOUSING", "SOCIAL_SUPPORT"
  
  // NEW: Category type - MAIN for primary listings, COMPLIMENTARY for service providers
  type          String   @default("MAIN") // "MAIN" or "COMPLIMENTARY"
  
  name          String   
  slug          String   // e.g., "plumbing"
  description   String?

  // UI & Branding (Shared by Website and Dashboard)
  icon          String?  // e.g., "home", "briefcase", "heart" (Lucide/Heroicons names)
  color         String?  // e.g., "#3B82F6" for branding specific sub-pillars
  
  // Hierarchy Logic
  parentId      String?
  parent        Category?  @relation("Subcategories", fields: [parentId], references: [id])
  subcategories Category[] @relation("Subcategories")
  
  // Relationships
  jobPosts         JobPost[]          @relation("MainCategory")
  subCategoryPosts JobPost[]          @relation("SubcategoryPosts")
  serviceOfferings    ServiceOffering[] @relation("ServiceMainCategory")
  subServiceOfferings ServiceOffering[] @relation("ServiceSubcategory")
  supportPrograms    SupportProgram[] @relation("SupportMainCategory")
  supportSubPrograms SupportProgram[] @relation("SupportSubcategory")
  contractorPricingRules ContractorPricingRule[]

  houseListings    HouseListing[]     @relation("HouseMainCategory")
  houseSubListings HouseListing[]     @relation("HouseSubcategory")


  version Int @default(1)

  hasSubcategories Boolean @default(false)
  hasParent        Boolean @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([vertical, slug])
  @@index([vertical])
  @@index([type]) // Add index for faster filtering by type
}


/// =====================================================================
///                            JOB POSTS
/// =====================================================================
model JobPost {
  id          String   @id @default(cuid())
  externalId  String   @default(uuid())
  title       String
  description String
  categoryId  String
  category    Category @relation("MainCategory", fields: [categoryId], references: [id])

  subCategoryId  String?
  subCategory    Category? @relation("SubcategoryPosts", fields: [subCategoryId], references: [id])

  creatorName   String?
  accountName   String?
  creatorId   String   // The individual user who clicked "Post"
  accountId   String   // The Org or Individual Account owning the post
  jobType     String
  locationCity String
  locationNeighborhood String?
  isRemote   Boolean @default(false)

  requiresDocuments Boolean @default(false)
  requiresEquipment Boolean @default(false)

  allowReferrals    Boolean @default(true) 
  referralBonus     Float?  // If the employer is offering money for a successful referral

  // NEW SOURCE OF TRUTH
  isNegotiable    Boolean @default(false)

  payAmount Float?
  payRate   String?
  skills    String[] @default([])
  experienceLevel String?
  employmentType String?
  documentsNeeded String[] @default([])
  equipmentRequired String[] @default([])
  additionalNotes String?
  status String @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications JobPostApplication[]
  ratings     Rating[]


  @@index([locationCity])
  @@index([status])
  @@index([creatorId]) // Good for "My Posts" dashboard
  @@index([accountId])
  @@index([categoryId])
}


/// =====================================================================
///                        JOB POST APPLICATIONS
/// =====================================================================
model JobPostApplication {
  id           String   @id @default(cuid())
  externalId   String   @default(uuid())

  // ======================
  // Relations
  // ======================
  jobPostId    String
  jobPost      JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  applicantId  String   // User ID from Identity Service
  employerId   String   // Denormalized for fast dashboard queries

  // ======================
  // Referral Details
  // ======================
  referrerName         String?
  referrerPhone        String?
  referrerEmail        String? // Kept for Formal Pillar background checks
  referrerRelationship String? // e.g., "Former Manager", "Vouched Colleague"

  // ======================
  // Applicant Intent & Compliance
  // ======================
  expectedPay          Float?
  availabilityDate     DateTime?
  availabilityNotes    String?
  
  // Handshake: Worker confirms they have the tools mentioned in JobPost
  hasRequiredEquipment Boolean @default(false) 

  // ======================
  // Status & Decisioning
  // ======================
  status            String    @default("PENDING") 
  employerNotes     String?
  rejectionReason   String?
  agreedPay         Float?    // The final negotiated rate
  agreedStartDate   DateTime?

  // ======================
  // Lifecycle Timestamps
  // ======================
  reviewedAt   DateTime?
  decidedAt    DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ======================
  // Relations
  // ======================
  attachments   JobApplicationAttachment[]
  statusHistory JobApplicationStatusHistory[]

  // ======================
  // Constraints & Indexes
  // ======================
  @@unique([jobPostId, applicantId])
  @@index([applicantId])
  @@index([employerId])
  @@index([jobPostId])
  @@index([status])
  @@index([referrerPhone])
  @@index([referrerEmail]) // Added index for referral lookups
}

model JobApplicationAttachment {
  id             String   @id @default(cuid())
  externalId     String   @default(uuid())

  applicationId  String
  application    JobPostApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // ======================
  // Document Metadata
  // ======================
  type        String
  /*
    CV
    COVER_LETTER
    ID
    CERTIFICATE
    LICENSE
    PORTFOLIO
    OTHER
  */

  fileUrl     String
  fileName    String?
  mimeType    String?
  fileSize    Int?

  // Optional structured text (important!)
  contentText String?
  /*
    Used when:
    - Cover letter is typed, not uploaded
    - Lightweight informal applications
  */

  isPrimary   Boolean @default(false)
  isRequired  Boolean @default(false)

  createdAt   DateTime @default(now())

  @@index([applicationId])
  @@index([type])
}

model JobApplicationStatusHistory {
  id             String   @id @default(cuid())

  applicationId  String
  application    JobPostApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  oldStatus      String
  newStatus      String
  changedBy      String   // User/Admin/Employer ID
  reason         String?

  createdAt      DateTime @default(now())

  @@index([applicationId])
  @@index([newStatus])
}

/// =====================================================================
///                    SKILLED PROFESSIONAL SERVICE OFFERINGS
/// =====================================================================
model ServiceOffering {
  id           String   @id @default(cuid())
  externalId   String   @default(uuid()) @unique
  
  // --- EXTERNAL IDENTITY ANCHORS (From Profile Service) ---
  creatorId    String   
  accountId    String   
  skilledProfessionalId String  
  
  // --- DENORMALIZED FIELDS (From Profile Service) ---
  professionalName   String?
  professionalAvatar String?
  isVerified         Boolean   @default(false)
  yearsExperience    Int?
  hourlyRate         Float?
  
  // --- SERVICE COVERAGE ---
  coverageAreas      Json?     
  
  // --- LISTING DETAILS ---
  title        String   
  description  String
  
  // Categories
  categoryId   String
  category     Category @relation("ServiceMainCategory", fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   Category? @relation("ServiceSubcategory", fields: [subCategoryId], references: [id])
  
  // --- PRICING ---
  basePrice    Float
  priceUnit    String   @default("PER_HOUR")
  currency     String   @default("KES")
  
  // ========== SERVICE-LEVEL BOOKING FEE (OVERRIDE) ==========
  // When true, use the override values below instead of profile defaults
  useCustomBookingFee      Boolean   @default(false)

  // ========== NEGOTIABLE PRICING ==========
  isNegotiable        Boolean   @default(true)   // Can customer negotiate the price?
  minNegotiablePrice  Float?                     // Minimum price willing to accept (if negotiable)
  maxNegotiablePrice  Float?                     // Maximum price (if they have an upper limit)
  
  // Override values (only used if useCustomBookingFee = true)
  customBookingFeeEnabled  Boolean?  // Override the enabled status
  customBookingFeeAmount   Float?    // Specific amount for THIS service
  customBookingFeeCurrency String?   @default("KES")
  customBookingFeeDescription String? // Custom description for this service
  customBookingFeeRefundable Boolean? // Custom cancellation policy
  
  // --- AVAILABILITY & SCHEDULING ---
  availability    String?
  status     String   @default("ACTIVE")
  expiresAt  DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // --- RELATIONSHIPS ---
  bookings        ServiceBooking[]
  reviews         Rating[] @relation("ServiceReviews")
  
  // --- INDEXES ---
  @@index([skilledProfessionalId])
  @@index([accountId])
  @@index([creatorId])
  @@index([categoryId])
  @@index([status])
  @@index([useCustomBookingFee])
  @@index([createdAt])
}

enum BookingStatus {
  PENDING    // Booking created, waiting for contractor response
  CONFIRMED  // Contractor accepted the booking
  CANCELLED  // Cancelled by client or contractor (after confirmation)
  DECLINED   // Contractor declined the booking
}

// This stays the same - tracks professional's actions
enum ServiceExecutionStatus {
  NOT_STARTED   // Professional hasn't started yet
  IN_PROGRESS   // Professional is currently working
  COMPLETED     // Professional says work is done
}

// NEW: Tracks customer's satisfaction level
enum CustomerSatisfaction {
  PENDING       // Customer hasn't responded yet (default)
  SATISFIED     // Customer confirms work is good
  DISSATISFIED  // Customer says work is bad (triggers dispute)
}

/// =====================================================================
///                           DISPUTE MANAGEMENT
/// =====================================================================

enum DisputeStatus {
  UNDER_REVIEW  // Dispute raised, waiting for admin action
  RESOLVED      // Admin has made a decision
  CLOSED        // Dispute is closed (no further action)
}

enum DisputeRaisedBy {
  CUSTOMER
  PROFESSIONAL
}

enum DisputeResolution {
  FULL_REFUND        // Customer gets all money back, professional gets nothing
  PARTIAL_REFUND     // Customer gets partial refund, professional gets rest
  RELEASE_PAYMENT    // Professional gets full payment, customer gets nothing
  CANCEL_BOOKING     // Booking cancelled, follow cancellation policy
}

enum DisputeDecision {
  IN_FAVOR_OF_CUSTOMER
  IN_FAVOR_OF_PROFESSIONAL
  SPLIT
}

model Dispute {
  id                String   @id @default(cuid())
  externalId        String   @default(uuid()) @unique
  
  // Relationship to the booking
  bookingId         String
  booking           ServiceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  // Who raised the dispute
  raisedBy          DisputeRaisedBy
  raisedByUserId    String        // UUID of the user who raised it
  
  // Dispute details
  title             String        // Short summary: "Professional never showed up"
  description       String?       // Detailed explanation
  reason            String        // e.g., "NO_SHOW", "POOR_WORK", "DID_NOT_START", "OTHER"
  
  // Evidence
  evidenceUrls      String[] @default([])  // Photos, screenshots, documents
  
  // Status tracking
  status            DisputeStatus @default(UNDER_REVIEW)
  
  // Resolution (set when resolved)
  resolution        DisputeResolution?
  decision          DisputeDecision?
  resolutionNotes   String?       // Admin's explanation of the decision
  
  // Financial outcome
  amountRefunded    Float?        // How much was refunded to customer
  amountReleased    Float?        // How much was released to professional
  platformFeeKept   Float?        // Platform commission kept (if any)
  
  // Who resolved it
  resolvedAt        DateTime?
  resolvedBy        String?       // Admin user ID who resolved
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  messages          DisputeMessage[]
  statusHistory     DisputeStatusHistory[]
  
  // Indexes
  @@index([bookingId])
  @@index([status])
  @@index([raisedByUserId])
  @@index([createdAt])
  @@index([resolvedAt])
}

model DisputeMessage {
  id                String   @id @default(cuid())
  externalId        String   @default(uuid()) @unique
  
  // Relationship
  disputeId         String
  dispute           Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  // Who sent the message
  senderId          String        // UUID of sender
  senderType        String        // "CUSTOMER", "PROFESSIONAL", "ADMIN"
  senderName        String?       // Denormalized for quick display
  
  // Message content
  message           String
  attachments       String[] @default([])  // File URLs
  
  // Read status
  readByCustomer    Boolean @default(false)
  readByProfessional Boolean @default(false)
  readByAdmin       Boolean @default(false)
  
  // Timestamps
  createdAt         DateTime @default(now())
  
  @@index([disputeId])
  @@index([createdAt])
  @@index([senderId])
}

model DisputeStatusHistory {
  id                String   @id @default(cuid())
  
  disputeId         String
  dispute           Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  
  oldStatus         DisputeStatus?
  newStatus         DisputeStatus
  changedBy         String        // User ID who changed the status
  changedByType     String        // "CUSTOMER", "PROFESSIONAL", "ADMIN", "SYSTEM"
  reason            String?
  
  createdAt         DateTime @default(now())
  
  @@index([disputeId])
  @@index([createdAt])
  @@index([changedBy])
}

/// =====================================================================
///                           CONTRACTOR SERVICE BOOKINGS
/// =====================================================================
model ServiceBooking {
  id            String   @id @default(cuid())
  externalId    String   @default(uuid()) @unique

  // ======================
  // THE WHO
  // ======================
  contractorId  String   
  clientId      String  

  // ======================
  // THE WHAT
  // ======================
  serviceId     String?
  service       ServiceOffering? @relation(fields: [serviceId], references: [id])

  // Denormalized for quick display
  contractorName String?
  contractorEmail String?
  contractorPhone String?
  clientName     String?
  clientPhone    String?
  clientEmail    String?
  serviceTitle   String?  

  // ======================
  // THE WHEN & WHERE
  // ======================
  status        BookingStatus @default(PENDING)
  scheduledDate DateTime?
  locationCity  String?

  reminderSent24h Boolean @default(false)
  reminderSent12h Boolean @default(false)
  reminderSent1h  Boolean @default(false)
  
  // ======================
  // PRICING BREAKDOWN
  // ======================
  servicePrice      Float?
  servicePriceUnit  String?
  serviceDuration   Int?
  
  bookingFeeAmount  Float?
  bookingFeeCurrency String?  @default("KES")
  bookingFeeRefundable Boolean? @default(false)
  
  totalAmount       Float?
  currency          String    @default("KES")
  customerNotes     String?
  
  // ======================
  // BOOKING LIFECYCLE TIMESTAMPS
  // ======================
  confirmedAt   DateTime?
  declinedAt    DateTime?
  cancelledAt   DateTime?
  completedAt   DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ======================
  // PROFESSIONAL'S ACTIONS
  // ======================
  serviceExecutionStatus ServiceExecutionStatus @default(NOT_STARTED)
  workStartedAt          DateTime?
  workCompletedAt        DateTime?
  
  // ======================
  // CUSTOMER'S SATISFACTION
  // ======================
  customerSatisfaction   CustomerSatisfaction @default(PENDING)
  customerConfirmedAt    DateTime?
  customerDissatisfiedAt DateTime?
  
  // ======================
  // EVIDENCE OF WORK
  // ======================
  completionEvidence   String[] @default([])
  
  // ======================
  // AUTO-RELEASE
  // ======================
  autoReleaseAt        DateTime?
  autoReleaseTriggered Boolean @default(false)
  
  // ======================
  // PAYMENT RELEASE TRACKING
  // ======================
  paymentReleasedAt    DateTime?
  refundAmount         Float?
  refundProcessedAt    DateTime?

  // ======================
  // RELATION TO DISPUTE
  // ======================
  disputes            Dispute[]  // A booking can have multiple disputes (though typically one)

  activeDisputeId     String?   @map("active_dispute_id")

  // ======================
  // INDEXES
  // ======================
  @@index([activeDisputeId])
  @@index([contractorId])
  @@index([clientId])
  @@index([status])
  @@index([serviceId])
  @@index([serviceExecutionStatus])
  @@index([customerSatisfaction])
  @@index([workCompletedAt])
  @@index([customerConfirmedAt])
  @@index([autoReleaseAt])
  @@index([paymentReleasedAt])
}

/// =====================================================================
///                           RATINGS & REVIEWS
/// =====================================================================
model Rating {
  id              String           @id @default(cuid())
  externalId      String           @default(uuid())  @unique
  
  // Relation to JobPost (Optional, for employer reviews)
  jobPostId       String?
  jobPost         JobPost?         @relation(fields: [jobPostId], references: [id])

  // Relation to ServiceOffering (Optional, for contractor reviews)
  serviceId       String?
  serviceOffering ServiceOffering? @relation("ServiceReviews", fields: [serviceId], references: [id])

  userId          String   // The person writing the review (Reviewer)
  rating          Int      // e.g., 1-5
  review          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// =====================================================================
///                            HOUSING (Asset-Driven) - UPDATED
/// =====================================================================
model HouseListing {
  id           String   @id @default(cuid())
  externalId   String   @default(uuid()) @unique
  creatorId    String
  creatorName  String?
  accountId    String
  accountName  String?
  
  title        String
  description  String

  categoryId   String
  category     Category @relation("HouseMainCategory", fields: [categoryId], references: [id])

  latitude    Float?
  longitude   Float?
  
  subCategoryId String?
  subCategory   Category? @relation("HouseSubcategory", fields: [subCategoryId], references: [id])
  
  // Listing type for rent vs sale - Values: "RENT", "SALE"
  listingType  String
  
  price        Float
  currency     String   @default("KES")

  ownerEmail   String?
  
  // Property details
  bedrooms     Int?
  bathrooms    Int?
  amenities    String[] @default([])
  isFurnished  Boolean  @default(false)
  
  // AI Training fields
  squareFootage Int?    // Total area in square feet/meters
  yearBuilt    Int?     // Construction year
  propertyType String?  // Validated against PROPERTY_TYPES constant
  
  // Rental-specific fields
  minimumLeaseTerm   Int?    // Minimum lease duration in months
  maximumLeaseTerm   Int?    // Maximum lease duration in months
  depositAmount      Float?  // Security deposit amount
  isPetFriendly      Boolean @default(false)
  utilitiesIncluded  Boolean @default(false)
  utilitiesDetails   String? // Which utilities are included (water, electricity, internet, etc.)
  
  // Sale-specific fields
  isNegotiable       Boolean @default(true)  // For sale price
  titleDeedAvailable Boolean @default(false) // Important for Kenyan property market
  
  // Location
  locationCity         String
  locationNeighborhood String?
  address              String?
  
  status       String   @default("AVAILABLE") // AVAILABLE, RENTED, SOLD, PENDING, UNAVAILABLE
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  images       HouseImage[]
  viewings     HouseViewing[]

  @@index([locationCity, listingType, categoryId])
  @@index([subCategoryId]) 
  @@index([creatorId])
  @@index([accountId])
  @@index([status])
  @@index([listingType])
  @@index([propertyType])
  @@index([price])
}

model HouseImage {
  id           String       @id @default(cuid())
  url          String
  isMain       Boolean      @default(false)
  houseId      String
  house        HouseListing @relation(fields: [houseId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt  
}

model HouseViewing {
  id           String       @id @default(cuid())
  houseId      String
  house        HouseListing @relation(fields: [houseId], references: [id])
  viewerId     String       // User ID
  viewingDate  DateTime
  notes        String?
  bookedById   String       // User ID who booked the viewing
  status       String       @default("SCHEDULED")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt  
}

/// =====================================================================
///                       SOCIAL SUPPORT (Impact-Driven)
/// =====================================================================
model SupportProgram {
  id           String   @id @default(cuid())
  externalId   String   @default(uuid()) @unique

  // --- IDENTITY ANCHORS ---
  // accountId refers to the root 'Account' (Individual or Organization) in Profile DB
  accountId      String   
  // creatorId refers to the specific human staff member/user who created this listing
  creatorId      String   

  // --- DENORMALIZED IDENTITY (For fast UI rendering) ---
  // Store the name of the NGO/Provider to avoid cross-service joins on every list view
  accountName    String
  creatorName    String?

  // Note: 'providerType' and 'isVerified' are removed here.
  // These are fetched/injected from the Account model in the Profile Service.

  title        String
  description  String

  // --- CATEGORIZATION ---
  categoryId    String
  category      Category @relation("SupportMainCategory", fields: [categoryId], references: [id])

  // NEW: Specific sub-pillar for targeted discovery
  subCategoryId String?
  subCategory   Category? @relation("SupportSubcategory", fields: [subCategoryId], references: [id])

  // Marketplace Discovery: e.g., "GRANT", "TRAINING", "FOOD_STAMP", "MENTORSHIP"
  supportType   String   @default("GENERAL")

  /// =====================================================
  /// ELIGIBILITY & TARGETING
  /// =====================================================
  eligibilityCriteria String?
  targetAudience      String[] @default([]) 
  
  // Handshake Requirements: Pre-conditions for the application process
  requiresIdVerification Boolean @default(false)
  requiresIncomeProof    Boolean @default(false)

  /// =====================================================
  /// COST & ACCESS
  /// =====================================================
  isFree     Boolean @default(true)
  baseCost   Float?  @default(0) 
  currency   String  @default("KES")

  /// =====================================================
  /// CAPACITY & IMPACT TRACKING
  /// =====================================================
  maxBeneficiaries     Int?      // Total available slots
  currentBeneficiaries Int       @default(0) // Successful approvals count
  
  // Financial Transparency: For sponsored/grant-based programs
  totalBudget          Float?    // Total funding allocated
  remainingBudget      Float?    // Funds left to disburse

  locationCity         String?
  locationNeighborhood String?

  /// =====================================================
  /// LIFECYCLE & METRICS
  /// =====================================================
  // DRAFT | ACTIVE | PAUSED | COMPLETED | ARCHIVED
  status    String    @default("DRAFT") 
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // RELATIONS
  applications SupportApplication[]
  milestones   SupportMilestone[]

  // INDEXES: Optimized for Marketplace Search & Discovery
  @@index([categoryId])
  @@index([locationCity])
  @@index([status])
  @@index([accountId])
  @@index([supportType])
}

model SupportApplication {
  id           String         @id @default(cuid())
  externalId   String         @default(uuid()) @unique
  
  programId    String
  program      SupportProgram @relation(fields: [programId], references: [id])
  
  beneficiaryId String        // The User UUID from Identity Service
  
  // Status Management: Matches the lifecycle of an "Opportunity"
  status       String         @default("PENDING") 
  // PENDING | UNDER_REVIEW | WAITLISTED | APPROVED | REJECTED | DISBURSED | CLOSED
  
  /// =====================================================
  /// BENEFICIARY SUBMISSION
  /// =====================================================
  statementOfNeed String?     
  requestedValue  Float?      // What the user is asking for (if variable)
  
  /// =====================================================
  /// REVIEW & AUDIT (The NGO/Provider side)
  /// =====================================================
  internalNGOAudit String?    // Private internal notes (Transparency for Admin)
  rejectionReason  String?
  reviewedById     String?    // UUID of the staff member who made the decision

  // Final Award Logic: The result of the "Connection"
  awardedAmount   Float?      // Final approved financial grant
  awardedQuantity Int?        // Final approved physical units (e.g., 2 bags of maize)
  awardedDetails  String?     // Description (e.g., "Full Scholarship covering Tuition")

  /// =====================================================
  /// HANDSHAKE & COMPLIANCE
  /// =====================================================
  // Tracks if the user has completed the program's requirements (e.g., ID check)
  isComplianceVerified Boolean @default(false)
  
  // Handshake: Beneficiary acknowledges the terms of the support
  termsAccepted        Boolean @default(false)
  acceptedAt           DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // RELATIONS
  benefits      SupportBenefit[] 
  documents     SupportDocument[]

  // CONSTRAINTS
  @@unique([programId, beneficiaryId]) // Prevents "Double Dipping" (Anti-fraud)
  @@index([beneficiaryId])
  @@index([status])
  @@index([programId])
}

model SupportBenefit {
  id              String             @id @default(cuid())
  applicationId   String
  application     SupportApplication @relation(fields: [applicationId], references: [id])
  
  // Snapshotted from the program to ensure historical audit integrity
  // e.g., "CASH_TRANSFER", "FOOD_BASKET", "VOUCHER", "EQUIPMENT"
  type            String             
  
  value           Float?             // Monetary value (e.g., 5000.00)
  quantity        Int?               @default(1) // For physical goods
  description     String?            // e.g., "January 2026 Stipend" or "Solar Lamp Kit"
  
  // Lifecycle: PENDING -> DISBURSED -> RECEIVED -> FAILED
  status          String             @default("PENDING") 
  
  /// =====================================================
  /// THE HANDSHAKE (Anti-Fraud Pillar)
  /// =====================================================
  confirmedByUser Boolean            @default(false)     // True only when beneficiary clicks "Confirm"
  confirmedAt     DateTime?
  
  // Optional: Reference to an external transaction (M-Pesa ID, Bank Ref, etc.)
  // This supports your Phase 2 Financial Integration goals.
  externalReference String?          @unique 

  /// =====================================================
  /// LOGISTICS & AUDIT
  /// =====================================================
  disbursedAt     DateTime?          // When the NGO sent the benefit
  receivedAt      DateTime?          // When the user actually got it
  
  createdAt       DateTime           @default(now())

  @@index([applicationId])
  @@index([status])
  @@index([externalReference])
}

model SupportDocument {
  id              String             @id @default(cuid())
  externalId      String             @default(uuid())
  
  applicationId   String
  application     SupportApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  // Document Classification
  // ID_CARD | INCOME_PROOF | DISABILITY_CERT | RESIDENCY_LETTER | ACADEMIC_CERT
  documentType    String             
  
  fileUrl         String             // S3/Cloud Storage link
  fileName        String?            // Original name (e.g., "ID_Front.jpg")
  
  // Verification Workflow
  isVerified      Boolean            @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?            // Admin/Staff User UUID who approved the doc
  rejectionReason String?            // If verification fails, why?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([applicationId])
  @@index([documentType])
}

model SupportMilestone {
  id          String         @id @default(cuid())
  externalId  String         @default(uuid()) @unique
  
  programId   String
  program     SupportProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  title       String         // e.g., "Orientation Meeting" or "Week 1 Skills Assessment"
  description String?
  
  // Sequencing
  order       Int            @default(0)
  
  // Required for Completion?
  isRequired  Boolean        @default(true)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([programId])
}

model ContractorPricingRule {
  id                   String   @id @default(uuid())
  vertical             String   
  unit                 String   

  // 1. Replace categorySlug string with categoryId
  categoryId           String?

  // 2. Define the relation with onDelete: Cascade
  // This ensures if a Category is deleted, these rules are also removed automatically.
  category             Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // ISO 4217 Currency Code (e.g., KES, USD, NGN)
  currency             String   @default("KES")

  minPrice             Float?   @default(0)
  maxPrice             Float?   
  isExperienceRequired Boolean  @default(false)
  isNotesRequired      Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  // 3. Update the unique constraint to use the ID
  @@unique([vertical, unit, currency, categoryId])
}

model SavedListing {
  id          String   @id @default(cuid())
  userUuid    String   // The Individual User
  
  // The listing being saved
  targetId    String   // externalId of Job, House, or SupportProgram
  vertical    String   // "JOBS" | "HOUSING" | "SOCIAL_SUPPORT" | "SERVICES"
  
  createdAt   DateTime @default(now())

  @@unique([userUuid, targetId])
  @@index([userUuid])
}

/// ======================================================
/// ADMIN AUDIT LOG (For tracking admin actions)
/// ======================================================
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String   // UUID of admin who performed the action
  action     String   // e.g., "SCHEDULE_VIEWING", "UPDATE_LISTING", "DELETE_LISTING"
  targetId   String   // ID of the affected record
  targetType String   // e.g., "HOUSE_VIEWING", "HOUSE_LISTING"
  metadata   Json?    // Additional context (IP, userAgent, etc.)
  timestamp  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([targetId])
  @@index([timestamp])
}