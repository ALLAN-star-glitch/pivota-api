// ======================================================
// LISTING MILESTONE EVENTS (from Housing Service)
// ======================================================

model ListingMilestoneEvent {
  id             String   @id @default(cuid())
  
  // Account/User info
  accountId      String
  accountName    String
  creatorId      String
  creatorName    String?
  
  // Listing details
  listingId      String
  listingTitle   String
  listingPrice   Float
  listingType    String
  locationCity   String
  categoryId     String?
  
  // Milestone data
  milestone      Int      // 1, 2, 3, 5, 10, 25, 50, 100
  milestoneTier  String   // ONBOARDING, ENGAGEMENT, GROWTH, POWER, PROFESSIONAL
  suggestedTeam  String   // onboarding, success, sales, marketing, partnerships
  
  // Calculated metrics
  totalListings  Int
  totalValue     Float
  averagePrice   Float
  daysSinceFirstListing Int?
  categories     Json?    // Array of categories used
  
  // Message and routing
  message        String
  priority       String   // HIGH, MEDIUM, LOW
  requiresFollowUp Boolean @default(false)
  
  // Device context (if available)
  deviceType     String?
  os             String?
  osVersion      String?
  browser        String?
  browserVersion String?
  isBot          Boolean? @default(false)
  platform       String?  // WEB, MOBILE, API, CLI
  
  // Timestamps
  occurredAt     DateTime // When the milestone was achieved
  createdAt      DateTime @default(now())

  // Indexes for querying
  @@index([accountId])
  @@index([milestone])
  @@index([milestoneTier])
  @@index([suggestedTeam])
  @@index([occurredAt])
  @@index([createdAt])
  
  // Composite indexes for analytics
  @@index([milestone, occurredAt])
  @@index([accountId, milestone])
  @@index([suggestedTeam, milestone])
}

