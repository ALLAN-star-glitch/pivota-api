// ======================================================
// ACCOUNT MILESTONE SUMMARY (for quick lookups)
// ======================================================

model AccountMilestoneSummary {
  id             String   @id @default(cuid())
  accountId      String   @unique
  accountName    String?  // Add this for easy identification
  
  // Latest milestone
  currentMilestone Int    @default(0) // Current listing count
  lastMilestone   Int?     // Last milestone achieved (1,2,3,5,10,etc.)
  lastMilestoneAt DateTime?
  
  // Milestone history
  milestonesAchieved Json? // [1,2,3,5] - which milestones they've hit
  
  // Account metrics
  totalListings   Int      @default(0)
  totalValue      Float    @default(0)
  averagePrice    Float?
  
  // First listing date
  firstListingAt  DateTime?
  daysActive      Int?     // Days since first listing
  
  // Categorization
  primaryCategory String?
  primaryLocation String?
  primaryListingType String?
  
  // Status
  isActive        Boolean  @default(true)
  lastActiveAt    DateTime?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([currentMilestone])
  @@index([lastMilestone])
  @@index([isActive])
}