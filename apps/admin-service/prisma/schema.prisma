  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cohortDate, acquisitionChannel, userType])
  @@index([cohortDate])
  @@index([churnRate])
  @@index([retentionDay30])
}

// ===================== FEATURE ADOPTION METRICS =====================

model FeatureAdoption {
  id              String   @id @default(cuid())
  featureName     String   // e.g., "MAP_VIEW", "PHOTO_SWIPE", "SAVE_LISTING"
  featureCategory String   // "SEARCH", "ENGAGEMENT", "CONVERSION", "SOCIAL"
  date            DateTime
  
  // ==================== USAGE METRICS ====================
  totalUsers      Int      @default(0) // Users who used feature
  newUsers        Int      @default(0) // First time using feature today
  returningUsers  Int      @default(0) // Used before, using again
  totalSessions   Int      @default(0) // Sessions with feature use
  totalUsage      Int      @default(0) // Total times feature used
  avgUsagePerUser Float?   // Average times used per user
  medianUsagePerUser Int?  // Median usage count
  usageDistribution Json?  // {1: 45, 2-5: 67, 6-10: 23, 10+: 12}
  
  // ==================== ADOPTION RATES ====================
  adoptionRate    Float?   // % of active users using feature
  weeklyAdoption  Float?   // % using in last 7 days
  monthlyAdoption Float?   // % using in last 30 days
  adoptionByUserType Json? // {"PROVIDER": 0.45, "BENEFICIARY": 0.67}
  adoptionByVertical Json? // {"HOUSING": 0.56, "JOBS": 0.34}
  
  // ==================== TIME TO ADOPTION ====================
  avgDaysToFirstUse Float? // Days from signup to first use
  medianDaysToFirstUse Int?
  cumulativeAdoption Json? // % adopted by day: {7: 0.23, 30: 0.45}
  
  // ==================== IMPACT METRICS ====================
  conversionRate   Float?  // % of users who completed action after using feature
  conversionLift   Float?  // Improvement vs non-users
  sessionLengthImpact Float? // Minutes added to session
  retentionImpact  Float?   // % improvement in 30-day retention
  satisfactionScore Float? // Based on post-interaction feedback (0-5)
  feedbackCount    Int     @default(0)
  positiveFeedback Int     @default(0)
  negativeFeedback Int     @default(0)
  
  // ==================== A/B TESTING ====================
  experimentId     String?
  experimentGroup String?  // "control", "treatment_a", etc.
  experimentVariant String?
  testMetric      Float?   // Primary metric for test
  testPValue      Float?   // Statistical significance
  testWinner      Boolean? // Whether this variant won
  
  // ==================== USER FEEDBACK ====================
  featureRequests Int      @default(0) // Times users asked for this
  featureComplaints Int    @default(0) // Negative feedback specific
  feedbackThemes  Json?    // Themes in user feedback
  
  // ==================== TECHNICAL METRICS ====================
  avgLoadTime     Float?   // Milliseconds
  errorRate       Float?   // % of uses with error
  crashRate       Float?   // % of sessions with crash
  usageByPlatform Json?    // {"MOBILE": 0.78, "WEB": 0.22}
  
  // ==================== TRENDS ====================
  dailyTrend      Json?    // Last 30 days of usage
  weeklyGrowth    Float?   // Week-over-week growth
  monthlyGrowth   Float?   // Month-over-month growth
  peakUsageHour   Int?     // Hour of day with most usage
  peakUsageDay    String?  // Day of week with most usage
  
  // ==================== PREDICTIONS ====================
  projectedAdoption Float? // Projected adoption in 30 days
  saturationPoint Float?   // Estimated max adoption rate
  
  @@unique([featureName, date, experimentGroup])
  @@index([featureName, date])
  @@index([featureCategory, date])
  @@index([adoptionRate])
}

// ======================================================
// KAFKA EVENTS FROM AUTH SERVICE
// ======================================================

model AuthEventLog {
  id             String   @id @default(cuid())
  
  // Event metadata
  eventType      String   // "user.registered", "user.login.google", "user.signup.failed", etc.
  serviceSource  String   @default("auth")
  
  // User info (anonymized for analytics)
  userUuid       String?
  email          String?  // Store only for debugging, consider hashing for production
  emailHash      String?  // For unique user tracking without PII
  
  // Event payload (full event data)
  payload        Json     // Complete event payload
  
  // Client info from AuthClientInfoDto
  clientInfo     Json?    // Store device, os, browser, etc. as JSON
  
  // Timestamps
  occurredAt     DateTime // When the event happened in auth service
  createdAt      DateTime @default(now())

  @@index([eventType])
  @@index([occurredAt])
  @@index([userUuid])
}

