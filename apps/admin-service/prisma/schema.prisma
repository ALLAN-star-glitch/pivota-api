  payload        Json     // Complete event payload
  
  // Client info from AuthClientInfoDto
  clientInfo     Json?    // Store device, os, browser, etc. as JSON
  
  // Timestamps
  occurredAt     DateTime // When the event happened in auth service
  createdAt      DateTime @default(now())

  @@index([eventType])
  @@index([occurredAt])
  @@index([userUuid])
}

