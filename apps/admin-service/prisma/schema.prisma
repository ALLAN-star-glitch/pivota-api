// ===================== GENERATOR & DATASOURCE =====================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===================== ROLES =====================

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?

  roleType    String   @unique
  scope       String
  status      String   @default("Active")
  immutable   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
  roleModules     RoleModule[]
}

// ===================== PERMISSIONS =====================

model Permission {
  id          String   @id @default(cuid())
  name        String
  action      String   @unique
  description String?

  moduleId    String?
  // Cascade here: If module is deleted, delete its permissions
  module      Module?   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  system      Boolean   @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

// ===================== USER → ROLE =====================

model UserRole {
  id       String   @id @default(cuid())
  userUuid String   @unique
  roleId   String

  role Role @relation(fields: [roleId], references: [id])
}

// ===================== ROLE → PERMISSION =====================

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String

  // Cascade here: If role or permission is deleted, remove the mapping
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ===================== MODULES =====================

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  system      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions   Permission[]
  planModules   PlanModule[]
  roleModules   RoleModule[]
  userModules   UserModule[]
}

// ===================== PLANS =====================

model Plan {
  id            String      @id @default(cuid())
  name          String      @unique
  slug          String      @unique
  description   String?
  totalListings Int         @default(0)
  features      String      // Store JSON: prices, support level, etc.
  creatorId     String

  isPremium     Boolean     @default(false)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  planModules   PlanModule[]
  subscriptions Subscription[]

  @@index([creatorId])
}

// ===================== PLAN → MODULE (Restrictions) =====================

model PlanModule {
  id           String   @id @default(cuid())
  planId       String
  moduleId     String
  restrictions String? 

  // Cascade here: If plan or module is deleted, remove restrictions
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, moduleId])
}

// ===================== ROLE → MODULE =====================

model RoleModule {
  id         String  @id @default(cuid())
  roleId     String
  moduleId   String
  assignable Boolean @default(false)

  // Cascade here: If role or module is deleted, remove visibility mapping
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}

// ===================== USER → MODULE =====================

model UserModule {
  id         String  @id @default(cuid())
  userUuid   String
  moduleId   String
  verified   Boolean  @default(false)
  approvedBy String?
  entityType String?
  orgName    String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Cascade here: If module is deleted, remove user activation status
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

// ===================== SUBSCRIPTIONS =====================

model Subscription {
  id           String   @id @default(cuid())
  accountUuid  String?               
  planId       String?              
  type         String   @default("PLAN") // PLAN, LISTING, MODULE
  entityIds    String[]             
  totalAmount  Float?               
  currency     String?  @default("KES")
  status       String   @default("ACTIVE") // ACTIVE, PARTIALLY_PAID, EXPIRED
  billingCycle String?
  amountPaid   Float?               
  startedAt    DateTime @default(now())
  expiresAt    DateTime
  endedAt      DateTime? 

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan         Plan?    @relation(fields: [planId], references: [id])

  @@index([accountUuid])
  @@index([status])
}

// ===================== ANALYTICS: AGGREGATED METRICS =====================
// Production-ready schema for PivotaConnect Analytics Module
// Optimized for: Founder Intelligence, Investor Reporting, SmartMatch™ AI

// ==================== MARKETPLACE STATS (Daily Snapshots) ====================

model MarketplaceStats {
  id              String   @id @default(cuid())
  date            DateTime @unique // Snapshot for a specific day
  
  // ==================== FINANCIALS ====================
  gmv             Float    @default(0) // Gross Merchandise Value
  commissions     Float    @default(0) // Platform commission earned
  escrowVolume    Float    @default(0) // Total in escrow
  payoutVolume    Float    @default(0) // Total paid out
  refunds         Float    @default(0) // Total refunded amount
  
  // Breakdown by vertical (stored as JSON for flexibility)
  gmvByVertical   Json?    // {"HOUSING": 150000, "JOBS": 75000, "SERVICES": 45000, "SOCIAL_SUPPORT": 25000}
  commissionsByVertical Json?
  
  // ==================== GROWTH ====================
  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0) // 30-day rolling
  newUsers        Int      @default(0) // New signups today
  returningUsers  Int      @default(0) // Users with prior sessions
  
  // Provider metrics
  totalProviders  Int      @default(0)
  newProviders    Int      @default(0)
  activeProviders Int      @default(0) // Posted/offered in last 30 days
  verifiedProviders Int    @default(0)
  
  // Consumer/Beneficiary metrics
  totalBeneficiaries Int   @default(0)
  newBeneficiaries Int     @default(0)
  activeBeneficiaries Int  @default(0)
  
  // ==================== OPERATIONS ====================
  // Jobs
  totalJobs       Int      @default(0)
  activeJobs      Int      @default(0)
  completedJobs   Int      @default(0)
  avgCompletionTime Float?  // In hours
  jobsByType      Json?    // {"FULL_TIME": 45, "PART_TIME": 23, "CONTRACT": 67}
  
  // Housing
  totalListings   Int      @default(0)
  activeListings  Int      @default(0)
  rentedListings  Int      @default(0)
  soldListings    Int      @default(0)
  listingsByType  Json?    // {"RENTAL": 234, "SALE": 56, "SHORT_STAY": 89}
  
  // Services
  totalServices   Int      @default(0)
  activeServices  Int      @default(0)
  completedBookings Int    @default(0)
  servicesByCategory Json?
  
  // Social Support
  totalPrograms   Int      @default(0)
  activePrograms  Int      @default(0)
  endedPrograms   Int      @default(0) // Renamed from completedPrograms to avoid ambiguity
  programsByType  Json?
  
  // ==================== MOBILE ENGAGEMENT ====================
  totalSessions   Int      @default(0)
  avgSessionDuration Float? // Minutes
  totalScreenViews Int     @default(0)
  
  // Interaction metrics
  totalSwipeCount Int      @default(0)
  avgSwipeCount   Float    @default(0) // Average swipes per session
  totalPhotoViews Int      @default(0)
  photoViewRate   Float    @default(0) // Avg photos viewed per listing
  totalMapExplores Int     @default(0)
  mapExploreRate  Float    @default(0) // % of sessions with map interaction
  
  // Feature usage
  savedItemsCount Int      @default(0)
  sharedItemsCount Int     @default(0)
  contactRequests Int      @default(0)
  
  // Platform breakdown
  sessionsByPlatform Json? // {"MOBILE": 1234, "WEB": 567, "SYSTEM": 89}
  devicesByOS     Json?    // {"iOS": 45, "Android": 52, "Other": 3}
  
  // ==================== SMARTMATCH™ PERFORMANCE ====================
  suggestionsShown Int     @default(0)
  suggestionsAccepted Int  @default(0)
  suggestionAcceptanceRate Float? // % of AI suggestions accepted
  
  searchesWithSuggestions Int @default(0)
  searchesWithoutSuggestions Int @default(0)
  searchPivotRate  Float?  // % of users changing filters after suggestions
  
  implicitDriftScore Float? // Avg deviation: stated preference vs behavior
  avgMatchScore    Float?   // Average match score for shown listings
  
  // Recommendation performance
  ctrByRecommendationType Json? // Click-through rate by recommendation type
  conversionByRecommendationType Json? // Conversion rate by type
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
}

// ==================== COUNTY METRICS ====================

model CountyMetrics {
  id              String   @id @default(cuid())
  countyName      String   // e.g., "Nairobi", "Mombasa"
  date            DateTime
  
  // ==================== DEMOGRAPHICS ====================
  totalPopulation Int      @default(0) // Total users in county
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  
  // Provider ecosystem
  providerCount   Int      @default(0)
  verifiedProviders Int    @default(0)
  newProviders    Int      @default(0)
  
  // Beneficiary ecosystem
  beneficiaryCount Int     @default(0)
  newBeneficiaries Int     @default(0)
  
  // ==================== HOUSING METRICS ====================
  housingListingCount    Int      @default(0)
  housingActiveListings  Int      @default(0)
  housingNewListings     Int      @default(0)
  
  // Pricing
  housingAvgRent         Float?   // Average rent in county
  housingMinRent         Float?
  housingMaxRent         Float?
  housingAvgSalePrice    Float?
  
  // Inventory
  housingRentalListings  Int      @default(0)
  housingSaleListings    Int      @default(0)
  housingAvgBedrooms     Float?
  housingFurnishedPercent Float?   // % furnished
  
  // Demand
  housingListingViews    Int      @default(0)
  housingViewingRequests Int      @default(0)
  housingApplications    Int      @default(0) // Rental applications
  
  // ==================== JOBS METRICS ====================
  jobsJobCount        Int      @default(0)
  jobsActiveJobs      Int      @default(0)
  jobsNewJobs         Int      @default(0)
  
  // Compensation
  jobsAvgSalary       Float?
  jobsMinSalary       Float?
  jobsMaxSalary       Float?
  
  // Job types
  jobsFullTime    Int      @default(0)
  jobsPartTime    Int      @default(0)
  jobsContract    Int      @default(0)
  jobsRemote      Int      @default(0)
  
  // Demand
  jobsViews        Int      @default(0)
  jobsApplications Int      @default(0)
  jobsFilled      Int      @default(0)
  
  // ==================== SOCIAL SUPPORT METRICS ====================
  supportActivePrograms  Int      @default(0)
  supportNewPrograms     Int      @default(0)
  
  // Reach
  supportBeneficiaries   Int      @default(0)
  supportApplications    Int      @default(0)
  supportApprovedApplications Int @default(0)
  
  // Financial
  supportTotalBudget     Float    @default(0)
  supportTotalAidDisbursed Float  @default(0)
  supportAvgAwardAmount  Float?
  
  // Program types
  supportProgramsByType  Json?    // {"GRANT": 3, "FOOD": 5, "TRAINING": 2}
  
  // ==================== SERVICES METRICS ====================
  servicesProviderCount Int     @default(0)
  servicesActiveListings  Int      @default(0)
  servicesTotalBookings   Int      @default(0)
  servicesCompletedBookings Int    @default(0)
  servicesAvgRating       Float?
  
  // ==================== ECONOMIC IMPACT ====================
  totalRevenue    Float    @default(0) // GMV from county
  platformCommission Float  @default(0)
  avgTransactionValue Float?
  
  // Employment impact
  jobsCreated     Int      @default(0) // Through platform
  estimatedIncome Float?   // Estimated total income to providers
  
  // ==================== ENGAGEMENT ====================
  mobileUsers     Int      @default(0) // Users from this county
  webUsers        Int      @default(0)
  avgSessionDuration Float? // Minutes
  totalSessions   Int      @default(0)
  
  // Time analysis
  peakActivityDay String?   // Day with most activity
  peakActivityHour Int?     // Hour with most activity
  
  // Geographic density
  latitude        Float?    // County center for maps
  longitude       Float?
  populationDensity Float?  // Users per sq km
  
  @@unique([countyName, date])
  @@index([countyName])
  @@index([date])
  @@index([totalRevenue])
}

// ==================== CATEGORY METRICS ====================

model CategoryMetrics {
  id              String   @id @default(cuid())
  categorySlug    String   // e.g., "plumbing", "apartments", "food-aid"
  vertical        String   // "HOUSING", "JOBS", "SOCIAL_SUPPORT", "SERVICES"
  date            DateTime

  // ==================== CORE METRICS (All Verticals) ====================
  
  /// Supply Side
  totalListings    Int      @default(0) // Jobs, Houses, Programs, Services
  activeListings   Int      @default(0)
  newListings      Int      @default(0) // Created in period
  expiredListings  Int      @default(0) // Expired/deactivated
  
  // Provider metrics (Global - applies to all verticals)
  creatorAccounts      Int      @default(0) // Unique accounts posting
  repeatCreatorAccounts Int    @default(0) // Providers with >1 listing
  verifiedCreatorAccounts Int @default(0)
  
  /// Demand Side
  totalViews       Int      @default(0)
  uniqueViewers    Int      @default(0)
  avgViewDuration  Int?     // Seconds spent viewing
  viewToActionRate Float?   // % of views that lead to action
  
  // Engagement
  savesCount       Int      @default(0)
  sharesCount      Int      @default(0)
  reportsCount     Int      @default(0)
  contactCount     Int      @default(0) // Contact provider clicks
  
  // Search visibility
  searchAppearances Int     @default(0) // Times appeared in search
  avgSearchPosition Float?   // Average position in search results
  
  // ==================== HOUSING SPECIFIC ====================
  
  /// Listings Breakdown
  housingRentalListings   Int      @default(0)
  housingSaleListings     Int      @default(0)
  housingShortstayListings Int     @default(0)
  housingCommercialListings Int    @default(0)
  
  /// Pricing
  housingAvgRentPrice     Float?   // Monthly rent average
  housingAvgSalePrice     Float?   // Sale price average
  housingAvgPricePerSqm   Float?   // For comparison
  housingMinPrice         Float?
  housingMaxPrice         Float?
  housingPriceVolatility  Float?   // Price variance indicator
  
  /// Property Stats
  housingAvgBedrooms      Float?
  housingAvgBathrooms     Float?
  housingAvgSize          Float?   // Square meters
  housingFurnishedPercent Float?   // % of listings that are furnished
  housingAmenitiesCount   Float?   // Average amenities per listing
  
  /// Popular Amenities
  housingTopAmenities     Json?    // ["wifi", "parking", "security"]
  
  /// Engagement
  housingPhotoViews       Int      @default(0)
  housingPhotoSwipeCount  Int      @default(0)
  housingAvgPhotosPerListing Float?
  housingMapExplores      Int      @default(0)
  
  /// Conversion Funnel
  housingViewingRequests  Int      @default(0)
  housingApplications     Int      @default(0) // Rental applications
  housingViewingToApplicationRate Float?
  housingListingsWithViewings Int  @default(0)
  
  /// Market Health
  housingDaysOnMarket     Float?   // Average days until rented/sold
  housingTurnoverRate     Float?   // Listings rented/sold / total listings
  housingPriceReductionCount Int   @default(0) // Listings with price drops
  
  // ==================== JOBS SPECIFIC ====================
  
  /// Job Types
  jobsFullTime     Int      @default(0)
  jobsPartTime     Int      @default(0)
  jobsContract     Int      @default(0)
  jobsTemporary    Int      @default(0)
  jobsInternship   Int      @default(0)
  jobsFreelance    Int      @default(0)
  
  /// Work Mode
  jobsRemote       Int      @default(0)
  jobsHybrid       Int      @default(0)
  jobsOnSite       Int      @default(0)
  
  /// Compensation
  jobsAvgSalary        Float?   // Average pay amount
  jobsMinSalary        Float?
  jobsMaxSalary        Float?
  jobsSalaryCurrency   String?  @default("KES")
  jobsNegotiated       Int      @default(0) // Jobs marked as negotiable
  jobsWithBenefits     Int      @default(0) // Jobs listing benefits
  
  /// Referrals
  jobsReferral         Int      @default(0)
  jobsAvgReferralBonus Float?
  jobsMaxReferralBonus Float?
  
  /// Skills & Requirements
  jobsTopSkills        Json?    // Most requested skills in category
  jobsAvgSkillsPerJob  Float?   // Average skills required
  jobsExperienceLevels Json?    // {"ENTRY": 45, "MID": 67, "SENIOR": 23}
  
  /// Education Requirements
  jobsEducationLevels  Json?    // {"HIGH_SCHOOL": 34, "CERTIFICATE": 56, "DEGREE": 78}
  
  /// Conversion
  jobsApplications     Int      @default(0)
  jobsApplicationsPerJob Float?
  jobsWithApplications Int @default(0)
  jobsFilled           Int      @default(0)
  jobsFillRate         Float?   // % of jobs filled
  
  /// Timing
  jobsAvgTimeToFill    Float?   // Days
  jobsAvgTimeToFirstApplication Float? // Hours
  
  /// Employer Quality
  jobsRepeatEmployers  Int      @default(0)
  jobsAvgEmployerRating Float?
  
  // ==================== SOCIAL SUPPORT SPECIFIC ====================
  
  /// Program Types
  supportGrantPrograms    Int      @default(0)
  supportTrainingPrograms Int      @default(0)
  supportFoodPrograms     Int      @default(0)
  supportHealthPrograms   Int      @default(0)
  supportEducationPrograms Int     @default(0)
  supportHousingAssistance Int     @default(0)
  supportEmergencyRelief  Int      @default(0)
  
  /// Capacity
  supportTotalCapacity    Int      @default(0) // Sum of maxBeneficiaries
  supportCurrentBeneficiaries Int @default(0)
  supportAvailableSlots   Int      @default(0)
  supportUtilizationRate  Float?   // % of capacity filled
  
  /// Financial
  supportTotalBudget      Float    @default(0)
  supportTotalDisbursed   Float    @default(0)
  supportRemainingBudget  Float    @default(0)
  supportBudgetUtilization Float?
  supportAvgAwardAmount   Float?
  supportMinAwardAmount   Float?
  supportMaxAwardAmount   Float?
  
  /// Accessibility
  supportFreePrograms     Int      @default(0) // isFree = true
  supportPaidPrograms     Int      @default(0)
  supportAvgCost          Float?   // For paid programs
  supportProgramsRequiringId Int   @default(0)
  supportProgramsRequiringProof Int @default(0)
  
  /// Impact Metrics
  supportApplications     Int   @default(0)
  supportApprovedApplications Int @default(0)
  supportRejectionRate     Float?
  supportBeneficiaryCompletions Int @default(0) // Users who completed programs
  supportCompletionRate    Float?
  
  /// Demographics Served
  supportTargetAudiences  Json?    // {"YOUTH": 45, "WOMEN": 67, "PWD": 23}
  
  /// Provider Quality
  supportProgramProviders  Int      @default(0)
  supportVerifiedProviders Int      @default(0)
  supportRepeatProviders   Int      @default(0)
  
  // ==================== SERVICES SPECIFIC (Contractor offerings) ====================
  
  /// Listings
  servicesListings   Int      @default(0)
  servicesActive     Int      @default(0)
  servicesNew        Int      @default(0)
  
  /// Provider Quality
  servicesTotalProviders    Int      @default(0)
  servicesVerifiedProviders Int      @default(0) // Count of verified accounts
  servicesAvgProviderRating Float?
  servicesProvidersWithReviews Int   @default(0)
  
  /// Pricing
  servicesAvgPrice   Float?
  servicesMinPrice   Float?
  servicesMaxPrice   Float?
  servicesFixedPrice    Int      @default(0)
  servicesHourlyRate    Int      @default(0)
  servicesAvgHourlyRate Float?
  
  /// Booking Metrics
  servicesTotalBookings     Int      @default(0)
  servicesCompletedBookings Int      @default(0)
  servicesCancelledBookings Int      @default(0)
  servicesBookingCompletionRate Float?
  
  /// Reviews
  servicesTotalReviews      Int      @default(0)
  servicesAvgRating         Float?
  servicesRatingDistribution Json?   // {5: 45, 4: 23, 3: 12, 2: 5, 1: 3}
  
  /// Provider Specialties
  servicesTopSpecialties    Json?    // Most common specialties
  
  /// Service Areas
  servicesAreaCoverage Json?  // Counties where services are offered
  
  // ==================== CROSS-VERTICAL METRICS ====================
  
  /// Financial Impact
  totalRevenue      Float    @default(0) // GMV generated
  platformCommission Float   @default(0) // Commission earned
  avgTransactionValue Float?
  
  /// User Impact
  uniqueProviders   Int      @default(0) // Unique accounts providing
  uniqueBeneficiaries Int    @default(0) // Unique users benefiting
  newUsersFromCategory Int   @default(0) // Users who joined via this category
  
  /// Geographic Distribution
  locationBreakdown Json?    // { "Nairobi": 45, "Mombasa": 23, "Kisumu": 12 }
  topLocations      Json?    // Top 5 locations by volume
  
  /// Temporal Patterns
  peakHours         Json?    // When most viewed/applied (0-23)
  peakDays          Json?    // Days of week with most activity
  seasonalTrend     Float?   // Seasonal adjustment factor
  
  /// Growth Trends
  momGrowth         Float?   // Month-over-month growth
  yoyGrowth         Float?   // Year-over-year growth
  categoryHealth    Float?   // Composite health score (0-100)
  
  /// Competitive Landscape
  providerConcentration Float? // HHI index for provider concentration
  avgListingsPerProvider Float?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([categorySlug, vertical, date])
  @@index([categorySlug, date])
  @@index([vertical, date])
  @@index([totalRevenue, date])
  @@index([totalViews, date])
}

// ==================== TRUST METRICS ====================

model TrustMetrics {
  id              String   @id @default(cuid())
  date            DateTime @unique
  
  // ==================== DISPUTES ====================
  disputesOpened  Int      @default(0)
  disputesResolved Int     @default(0)
  disputesEscalated Int    @default(0)
  disputesByVertical Json? // {"JOBS": 5, "HOUSING": 3, "SERVICES": 2}
  disputesByReason Json?   // {"PAYMENT": 4, "QUALITY": 3, "NO_SHOW": 2}
  
  // Resolution metrics
  avgResolutionTime Float? // In hours
  disputesInFavorOfConsumer Int @default(0)
  disputesInFavorOfProvider Int @default(0)
  disputeOutcomeRate Float? // % resolved in consumer favor
  
  // ==================== FRAUD ====================
  fraudFlags      Int      @default(0)
  confirmedFraud  Int      @default(0)
  falsePositives  Int      @default(0)
  fraudByType     Json?    // {"ACCOUNT_TAKEOVER": 2, "FAKE_LISTING": 5, "PAYMENT_FRAUD": 3}
  
  // ==================== ACCOUNT ACTIONS ====================
  suspensions     Int      @default(0)
  permanentBans   Int      @default(0)
  temporaryLocks  Int      @default(0)
  warningsIssued  Int      @default(0)
  
  actionsByReason Json?    // {"FRAUD": 4, "ABUSE": 3, "SPAM": 5}
  
  // ==================== VERIFICATION METRICS ====================
  verifiedAccounts Int     @default(0)
  verificationRate Float?  // % of accounts verified
  pendingVerifications Int @default(0)
  rejectedVerifications Int @default(0)
  
  verificationByType Json? // {"NATIONAL_ID": 234, "BUSINESS_REG": 56, "KRA_PIN": 89}
  avgVerificationTime Float? // Hours
  
  // ==================== SAFETY & CONTENT MODERATION ====================
  flaggedListings  Int     @default(0)
  removedListings  Int     @default(0)
  reinstatedListings Int   @default(0)
  
  userReports      Int     @default(0)
  uniqueReporters  Int     @default(0)
  reportsByType    Json?   // {"SCAM": 5, "INAPPROPRIATE": 3, "DUPLICATE": 2}
  
  // Auto-moderation
  autoFlagged      Int     @default(0)
  autoRemoved      Int     @default(0)
  humanReviewed    Int     @default(0)
  
  // ==================== COMPLIANCE ====================
  gdprRequests     Int     @default(0)
  dataDeletions    Int     @default(0)
  legalHolds       Int     @default(0)
  
  // ==================== TRUST SCORES ====================
  avgTrustScore    Float?  // Average platform trust score (0-100)
  trustScoreByVertical Json?
  
  // Risk indicators
  highRiskUsers    Int     @default(0)
  highRiskListings Int     @default(0)
  riskDistribution Json?   // {"LOW": 456, "MEDIUM": 123, "HIGH": 45}
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([date])
}

// ===================== USER INTERACTION EVENTS (For AI SmartMatch™) =====================
// This is the raw event stream for ML training and real-time personalization

model UserEvent {
  id           String   @id @default(cuid())
  userUuid     String?  // References User.uuid in Profile Service
  sessionId    String?  // References Session.tokenId in Auth Service
  
  // ==================== CONTEXT ====================
  platform     String   @default("MOBILE") // MOBILE, WEB, or SYSTEM
  eventType    String   // VIEW, CLICK, SAVE, SHARE, APPLY, CONTACT, etc.
  vertical     String   // "HOUSING", "JOBS", "SOCIAL_SUPPORT", "SERVICES"
  
  // Event classification
  eventCategory String  // "VIEW", "INTERACTION", "CONVERSION", "PREFERENCE"
  eventAction   String  // Specific action within category
  
  // ==================== TARGET ====================
  targetId     String?  // externalId of Job, House, Service, or Program
  targetType   String?  // "JOB", "HOUSING", "SERVICE", "SUPPORT"
  targetOwnerId String? // UUID of listing owner (for trust signals)
  
  // Category info (denormalized for speed)
  categorySlug String?  // Category of the target
  subCategorySlug String?
  
  // ==================== ENGAGEMENT METRICS ====================
  dwellTime    Int?     // Seconds spent on this interaction
  swipeCount   Int?     // Number of swipes in this session/event
  scrollDepth  Int?     // % of page scrolled (0-100)
  photoIndices Int[]    // Which photos they viewed (order)
  videoWatched Boolean? @default(false)
  videoDuration Int?    // Seconds of video watched
  
  // ==================== SEARCH CONTEXT ====================
  searchId     String?  // Group events from same search
  searchQuery  String?  // What they searched for
  searchResultsCount Int? // Number of results shown
  searchPosition Int?   // Position of clicked item (1-based)
  filters      Json?    // Active filters during interaction
  sortBy       String?  // How results were sorted
  
  // ==================== SMARTMATCH™ CONTEXT ====================
  recommendationId String? // ID of the recommendation if shown
  recommendationType String? // "AI_MATCH", "POPULAR", "NEARBY", "TRENDING"
  recommendationScore Float? // Match score if applicable
  userAcceptedSuggestion Boolean? // Did they accept AI suggestion
  
  // ==================== LOCATION CONTEXT ====================
  locationLat   Float?
  locationLng   Float?
  locationCity  String?
  locationCounty String?
  locationAccuracy Int?   // Meters
  
  // ==================== PRICING CONTEXT ====================
  priceViewed   Float?   // Price shown to user
  priceCurrency String?  @default("KES")
  comparedToAvg Float?   // How this price compares to category avg (-0.2 = 20% below avg)
  
  // ==================== USER STATE ====================
  userType      String?  // "PROVIDER", "BENEFICIARY", "BOTH"
  userTrustScore Float?  // User's trust score at time of event
  userVerificationLevel String? // "NONE", "BASIC", "VERIFIED"
  
  // Session info
  sessionNumber Int?     // User's nth session
  eventsInSession Int?   // Total events in this session
  timeInSession Int?     // Seconds into session
  
  // ==================== DEVICE INFO ====================
  os           String?  
  osVersion    String?
  deviceModel  String?  
  deviceBrand  String?
  browser      String?
  browserVersion String?
  appVersion   String?  // Mobile app version
  screenSize   String?  // e.g., "375x812"
  networkType  String?  // "WIFI", "4G", "5G"
  
  // ==================== METADATA ====================
  metadata     Json     // Flexible catch-all for AI training
  
  // Referrer info
  referrerUrl  String?  // Where they came from
  referrerType String?  // "DIRECT", "SEARCH", "SOCIAL", "EMAIL"
  
  // A/B testing
  experimentId String?
  experimentVariant String?
  
  createdAt    DateTime @default(now())

  // Comprehensive indexes for AI queries
  @@index([userUuid, createdAt])
  @@index([sessionId])
  @@index([eventType, vertical, createdAt])
  @@index([targetId, targetType])
  @@index([searchId])
  @@index([recommendationId])
  @@index([locationCity, eventType])
  @@index([categorySlug, eventType])
  @@index([createdAt])
  
  // Compound indexes for common AI patterns
  @@index([userUuid, eventType, targetType])
  @@index([userUuid, vertical, createdAt])
  @@index([targetId, eventType])
}

// ===================== SMARTMATCH™ FEATURE STORE =====================
// This model directly answers the AI developer's 28 feature requirements
// Pre-computed features for ML training and inference

model SmartMatchy {
  id              String   @id @default(cuid())
  
  // ==================== COMPOSITE IDENTIFIERS ====================
  userUuid        String   // The user
  listingId       String   // The listing (house, job, service, program)
  vertical        String   // "HOUSING", "JOBS", "SOCIAL_SUPPORT", "SERVICES"
  interactionId   String?  // Link to specific UserEvent if applicable
  
  // Timestamp for time-based features
  timestamp       DateTime @default(now())
  featureSetVersion String  // Version of feature engineering pipeline
  
  // ==================== USER PREFERENCES (Features 1-8) ====================
  
  /// Budget Features
  userMaxBudget   Float?   // Feature 1: Maximum budget user is willing to spend
  userMinBudget   Float?   // User's minimum budget (if specified)
  userBudgetMidpoint Float? // Feature 2: Middle value of user's budget range
  userBudgetFlexibility Float? // 0-1 indicating how flexible on price
  
  /// Bedroom Preferences
  userMinBedrooms Int?     // Feature 3: Minimum number of bedrooms
  userMaxBedrooms Int?     // Feature 4: Maximum number of bedrooms
  userPreferredBathrooms Int? // Preferred number of bathrooms
  
  /// Property Preferences
  userPropertyType String? // Feature 5: Type of property preferred (apartment, house, etc.)
  userPreferredPropertyTypes Json? // ["APARTMENT", "HOUSE"]
  
  /// Location Preferences
  userPreferredNeighborhood String? // Feature 6: Preferred neighborhood or area
  userPreferredLat     Float?       // Feature 7: Preferred location latitude
  userPreferredLng     Float?       // Feature 8: Preferred location longitude
  userPreferredRadius  Float?       // Search radius in km
  userPreferredLocations Json?      // Array of preferred neighborhoods/cities
  
  /// Amenity Preferences
  userFavoriteAmenities Json?       // Array of amenities user prefers
  userPreferredAmenities Json?      // Weighted amenities: {"wifi": 0.9, "parking": 0.8}
  
  /// Listing Type Preferences
  userPreferredListingTypes Json?   // ["RENTAL", "SALE"]
  
  /// User Context from Profile (Enriched by analytics)
  userPreviousSearches Json?        // Array of recent search queries
  userPreviousViewings Json?        // Array of recently viewed listing IDs
  
  // ==================== LISTING FEATURES (Features 9-18) ====================
  
  /// Price Features
  listingPrice        Float?        // Feature 9: Price of the house
  listingPriceCurrency String?       @default("KES")
  
  /// Property Details
  listingBedrooms     Int?           // Feature 10: Number of bedrooms
  listingBathrooms    Int?           // Feature 11: Number of bathrooms
  listingPropertyType String?        // Feature 12: Type of property
  listingSquareFootage Int?          // Square footage of property
  listingYearBuilt    Int?           // Year property was built
  
  /// Location Details
  listingNeighborhood String?        // Feature 13: Neighborhood or area
  listingLat          Float?         // Feature 14: Latitude
  listingLng          Float?         // Feature 15: Longitude
  listingLatitude     Float?         // Exact latitude
  listingLongitude    Float?         // Exact longitude
  
  /// Listing Metadata
  listingAge          Int?           // Feature 16: Days since posted
  listingPhotoCount   Int?           // Feature 17: Number of photos
  listingVerified     Boolean?       @default(false) // Feature 18: Whether verified
  listingStatus       String?        // "ACTIVE", "PENDING", "COMPLETED"
  listingCategoryId   String?        // Category ID
  listingCategorySlug String?        // Category slug
  listingAmenities    Json?          // Array of amenities
  listingIsFurnished  Boolean?       @default(false) // Whether furnished
  
  // ==================== SESSION CONTEXT (Features 19-22) ====================
  
  /// Referrer Information
  sessionReferrer     String?        // Feature 19: Where user came from
  sessionReferrerType String?        // "HOME", "SEARCH", "SIMILAR", "SAVED"
  
  /// Device Information - ENHANCED with all AuthClientInfoDto fields
  sessionDevice       String?        // Feature 20: Device being used (model name)
  sessionPlatform     String?        // "MOBILE", "WEB", "APP"
  deviceType          String?        // "MOBILE", "TABLET", "DESKTOP", "BOT"
  os                  String?        // Operating system name (iOS, Android, Windows)
  osVersion           String?        // Operating system version
  browser             String?        // Browser name (Chrome, Safari, Firefox)
  browserVersion      String?        // Browser version
  appVersion          String?        // App version if applicable
  isBot               Boolean?       @default(false) // Whether the request is from a bot
  
  /// Search Context
  sessionSearchId     String?        // Search session ID
  sessionSearchQuery  String?        // Search query text
  sessionSearchMaxBudget Float?      // Feature 21: Max budget in current search
  sessionSearchNeighborhood String?  // Feature 22: Neighborhood selected in current search
  sessionSearchFilters Json?         // All active filters
  searchPosition      Int?           // Position in search results
  
  /// Interaction Context
  interactionType     String?        // "CLICK", "SCROLL", "DWELL"
  scrollDepth         Int?           // % scrolled (0-100)
  viewDuration        Int?           // How long viewed in seconds
  timeSpent           Int?           // Time spent in seconds
  
  // ==================== USER-LISTING MATCH FEATURES (Features 23-28) ====================
  
  /// Budget Match
  isWithinBudget      Boolean?       // Feature 23: Whether house is within user's budget
  priceToBudgetDiff   Float?         // Feature 24: Difference from budget midpoint (negative = under)
  priceToBudgetRatio  Float?         // Feature 25: Price / Max Budget (0.0-1.0+)
  priceVsCategoryAvg  Float?         // Price compared to category average
  priceVsNeighborhoodAvg Float?      // Price compared to neighborhood average
  
  /// Bedroom Match
  bedroomDiff         Int?           // Feature 26: Difference from preferred bedrooms
  meetsBedroomRequirement Boolean?    // Whether within min/max range
  bathroomDiff        Int?           // Difference from preferred bathrooms
  
  /// Location Match
  locationDistance    Float?         // Feature 27: Distance in km between user pref and listing
  isPreferredNeighborhood Boolean?    // Feature 28: Whether in same preferred neighborhood
  locationMatchScore  Float?         // Composite location score
  isExactNeighborhoodMatch Boolean?   // Whether exact neighborhood match
  isCityMatch         Boolean?       // Whether same city
  distanceFromPreferred Float?       // Distance from preferred location
  
  /// Amenity Match
  amenityMatchScore   Float?         // How well amenities match user preferences
  amenityMatchCount   Int?           // Number of matching amenities
  
  /// Property Type Match
  propertyTypeMatch   Boolean?       // Whether property type matches preference
  propertyTypeMatchScore Float?      // 0-1 score for property type match
  
  // ==================== TEMPORAL FEATURES ====================
  
  hourOfDay           Int?            // Hour when event occurred (0-23)
  dayOfWeek           Int?            // Day of week (0-6, 0=Sunday)
  isWeekend           Boolean?        // Whether event on weekend
  daysSinceListingPosted Int?         // Age of listing at time of event
  timeToViewing       Int?            // For scheduled viewings: days until viewing
  
  // ==================== VIEWING-SPECIFIC FEATURES ====================
  
  /// Viewing Details (Added for SCHEDULE_VIEWING events)
  viewingDate         DateTime?       // When the viewing is scheduled - helps with time-based analysis
  isAdminBooking      Boolean?        @default(false) // Distinguish between user vs admin initiated
  viewingDuration     Int?            // Expected duration in minutes - indicates commitment level
  viewingParticipants Int?            // Number of people attending - indicates scale of interest
  
  // ==================== AI EVENT METADATA ====================
  
  aiEventType         String?        // "VIEW", "SEARCH", "SAVE", "SCHEDULE_VIEWING", etc.
  aiEventId           String?        // Reference to original event if needed
  aiEventTimestamp    DateTime?      // When the original event occurred
  
  // ==================== ADDITIONAL MATCH SCORES ====================
  
  // Composite scores
  overallMatchScore   Float?         // Final ranking score
  priceScore          Float?         // Normalized price match (0-1)
  locationScore       Float?         // Normalized location match (0-1)
  propertyScore       Float?         // Normalized property match (0-1)
  recencyScore        Float?         // Normalized recency match (0-1)
  
  // ==================== LABELS (For Training) ====================
  userClicked         Boolean?       @default(false) // Did user click/view
  userSaved           Boolean?       @default(false) // Did user save
  userContacted       Boolean?       @default(false) // Did user contact/apply
  userConverted       Boolean?       @default(false) // Did user complete transaction
  dwellTime           Int?           // If clicked, how long they viewed
  
  // Enhanced conversion labels
  userScheduledViewing Boolean?       @default(false) // Did they schedule viewing
  userCompletedViewing Boolean?       @default(false) // Did they complete viewing
  viewingCompletedAt  DateTime?       // When viewing actually occurred
  viewingFeedback     Json?           // Feedback from completed viewing
  
  // ==================== METADATA ====================
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  // ==================== ENHANCED INDEXES ====================
  
  // Existing indexes
  @@index([userUuid, timestamp])
  @@index([listingId, timestamp])
  @@index([vertical, timestamp])
  @@index([overallMatchScore])
  @@index([userClicked])
  @@index([userConverted])
  
  // Composite indexes for training batches
  @@index([timestamp, vertical, userClicked])
  @@index([vertical, isWithinBudget, userConverted])
  
  // NEW INDEXES for AI queries
  @@index([aiEventType, timestamp])
  @@index([listingPropertyType])
  @@index([listingSquareFootage])
  @@index([interactionType])
  @@index([hourOfDay])
  @@index([dayOfWeek])
  @@index([deviceType])
  @@index([os])
  @@index([browser])
  @@index([isBot])
  @@index([distanceFromPreferred])
  @@index([amenityMatchScore])
  @@index([userScheduledViewing])
  @@index([userCompletedViewing])
  @@index([listingNeighborhood, userPreferredNeighborhood])
  @@index([priceVsCategoryAvg])
  @@index([sessionSearchId])
  
  // New indexes for viewing-specific features
  @@index([viewingDate])
  @@index([isAdminBooking])
  @@index([viewingDuration])
}

// ===================== SMARTMATCH™ INSIGHTS (User Profiles) =====================
// Pre-computed user profiles for personalization

model SmartMatchInsight {
  id           String   @id @default(cuid())
  userUuid     String   @unique // One insight profile per user
  
  // ==================== USER SNAPSHOT ====================
  userType     String?  // "PROVIDER", "BENEFICIARY", "BOTH"
  accountAge   Int?     // Days since signup
  trustScore   Float?   // User's trust score
  isVerified   Boolean? @default(false)
  
  // ==================== EXPLICIT PREFERENCES ====================
  explicitPrefs Json    // Snapshot of stated preferences from:
                        // - HousingPreference (budget, bedrooms, neighborhood)
                        // - JobSeekerProfile (skills, job types)
                        // - UserProfile
  
  explicitPrefsUpdatedAt DateTime?
  
  // ==================== IMPLICIT SIGNALS ====================
  implicitPrefs Json    // Derived preferences from behavior:
                        // {
                        //   "preferredNeighborhoods": [
                        //     {"name": "Kilimani", "weight": 0.85},
                        //     {"name": "Lavington", "weight": 0.72}
                        //   ],
                        //   "priceRange": {
                        //     "min": 15000, 
                        //     "max": 45000,
                        //     "preferred": 25000,
                        //     "flexibility": 0.3
                        //   },
                        //   "preferredBedrooms": 2,
                        //   "bedroomFlexibility": 1
                        // }
  
  // ==================== ENGAGEMENT PATTERNS ====================
  avgSessionDuration Float? // Average time per session
  totalSessions     Int     @default(0)
  totalEvents       Int     @default(0)
  
  // Time patterns
  peakActivityHours  Int[]  // Hours when most active (0-23)
  peakActivityDays   Int[]  // Days of week (0-6, 0=Sunday)
  
  // Interaction patterns
  avgSwipeRate      Float? // Swipes per minute
  photoPreference   Float? // % of listings where they view photos
  mapUsageRate      Float? // % of sessions with map
  
  // ==================== CATEGORY AFFINITIES ====================
  categoryAffinities Json  // Weighted preferences by category:
                          // {
                          //   "apartments": 0.95,
                          //   "plumbing": 0.45,
                          //   "food-aid": 0.20
                          // }
  
  verticalAffinities Json // By vertical: {"HOUSING": 0.8, "JOBS": 0.3}
  
  // ==================== CONVERSION PREDICTORS ====================
  conversionProbability Json // ML model output:
                            // {
                            //   "application": 0.45,
                            //   "contact": 0.67,
                            //   "booking": 0.23
                            // }
  
  // ==================== RECOMMENDATION HISTORY ====================
  recommendationsShown Int @default(0)
  recommendationsClicked Int @default(0)
  recommendationsConverted Int @default(0)
  ctrByType         Json?   // Click-through rate by recommendation type
  
  // ==================== FEEDBACK LOOP ====================
  positiveFeedback  Json?   // Things user liked (saved, contacted)
  negativeFeedback  Json?   // Things user dismissed/ignored
  feedbackUpdatedAt DateTime?
  
  // ==================== MATCH SCORES (Cached) ====================
  lastComputed  DateTime @updatedAt
  matchVersion  String   // Version of matching algorithm
  confidenceScore Float? // Confidence in this user profile (0-1)
  
  // Pre-computed matches (for performance)
  topHousingMatches   Json?   // Top 10 housing recommendations
  
  // ==================== USER STATS ====================
  totalInteractions Int @default(0)
  uniqueListingsViewed Int @default(0)
  savedListingsCount Int @default(0)
  applicationCount Int @default(0)
  contactCount    Int @default(0)
  
  // ==================== LIFECYCLE STAGE ====================
  userStage       String? // "NEW", "ACTIVE", "ENGAGED", "DORMANT", "CHURNED"
  stageLastUpdated DateTime?
  
  // Churn risk
  churnRisk       Float?  // 0-1 probability of churn
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Comprehensive indexes
  @@index([userUuid])
  @@index([lastComputed])
  @@index([userStage])
  @@index([churnRisk])
  @@index([userType])
}

