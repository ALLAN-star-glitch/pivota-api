  totalListings   Int      @default(0)
  totalValue      Float    @default(0)
  averagePrice    Float?
  
  // First listing date
  firstListingAt  DateTime?
  daysActive      Int?     // Days since first listing
  
  // Categorization
  primaryCategory String?
  primaryLocation String?
  primaryListingType String?
  
  // Status
