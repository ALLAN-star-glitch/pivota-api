  approvalRate     Float?
  rejectedApplications Int @default(0)
  rejectionRate    Float?
  
  // Demographics served
  beneficiariesByDemographic Json? // {
                                   //   "YOUTH": 234,
                                   //   "WOMEN": 456,
                                   //   "PWD": 78,
                                   //   "ELDERLY": 123,
                                   //   "DISPLACED": 45
                                   // }
  
  // ==================== FINANCIAL IMPACT ====================
  totalBudget     Float    @default(0)
  totalDisbursed  Float    @default(0)
  remainingBudget Float    @default(0)
  budgetUtilization Float?
  disbursedByType Json?    // Disbursement by program type
  avgAwardAmount  Float?
  medianAwardAmount Float?
  minAwardAmount  Float?
  maxAwardAmount  Float?
  awardDistribution Json?  // Award percentiles
  
  // ==================== PROGRAM OUTCOMES ====================
  programsWithCompletions Int @default(0) // Programs that had beneficiaries complete
  beneficiaryCompletions Int @default(0) // Number of beneficiaries who completed
  completionRate   Float?
  outcomesByType  Json?    // Success metrics by program type
  
  // Impact metrics
  beneficiariesEmployed Int @default(0) // After training programs
  businessesStarted Int   @default(0) // After grant programs
  foodSecurityImproved Int @default(0) // After food programs
  
  // ==================== PROVIDER METRICS ====================
  uniqueProviders  Int      @default(0)
  newProviders     Int      @default(0)
  activeProviders  Int      @default(0)
  verifiedProviders Int     @default(0)
  avgProviderRating Float?
  providersWithHistory Int @default(0) // >1 year on platform
  
  // ==================== GEOGRAPHIC REACH ====================
  countiesServed   Int      @default(0)
  topCounties      Json?    // Top 5 counties by programs
  urbanVsRural     Json?    // {"URBAN": 45, "RURAL": 32, "PERI_URBAN": 12}
  
  // ==================== ACCESSIBILITY ====================
  programsRequiringId Int   @default(0)
  programsRequiringProof Int @default(0)
  avgDocsRequired   Float?
  languagesOffered Json?    // Languages programs are offered in
  
  // ==================== TIMELINESS ====================
  avgTimeToApproval Float?  // Days from application to decision
  avgTimeToDisbursement Float? // Days from approval to funds
  
  // ==================== TRENDS ====================
  monthlyTrend     Json?    // 12-month trend
  quarterlyGrowth  Float?
  yearOverYearGrowth Float?
  topNeeds         Json?    // Most requested support types
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([date])
}

// ===================== RETENTION & COHORT ANALYSIS =====================

model UserCohort {
  id              String   @id @default(cuid())
  cohortDate      DateTime // When users signed up (month)
  cohortSize      Int      @default(0)
  
  // ==================== COHORT IDENTIFICATION ====================
  acquisitionChannel String? // How they joined: "ORGANIC", "REFERRAL", "SOCIAL", "PAID"
  userType        String?    // "PROVIDER", "BENEFICIARY", "BOTH"
  vertical        String?    // Primary vertical: "HOUSING", "JOBS", "SOCIAL_SUPPORT"
  
  // ==================== RETENTION BY PERIOD ====================
  retentionDay7   Float?   // % active on day 7
  retentionDay14  Float?   // % active on day 14
  retentionDay30  Float?   // % active on day 30
  retentionDay60  Float?   // % active on day 60
  retentionDay90  Float?   // % active on day 90
  retentionDay180 Float?   // % active on day 180
  retentionDay365 Float?   // % active on day 365
  retentionCurve  Json?    // Array of [day, percentage] pairs
  
  // ==================== ENGAGEMENT METRICS ====================
  avgSessionsPerUser Float?
  avgEventsPerUser   Float?
  
  // Engagement by vertical
  housingUsers    Int      @default(0)
  jobsUsers       Int      @default(0)
  supportUsers    Int      @default(0)
  servicesUsers   Int      @default(0)
  multiVerticalUsers Int   @default(0) // Used >1 vertical
  crossVerticalRate Float? // % using multiple verticals
  
  // ==================== POWER USERS ====================
  powerUsers      Int      @default(0) // 20+ sessions
  superUsers      Int      @default(0) // 50+ sessions
  powerUserRate   Float?   // % of cohort that are power users
  
  // ==================== CONVERSION METRICS ====================
  usersWithFirstView Int   @default(0)
  usersWithFirstSave Int   @default(0)
  usersWithFirstApply Int  @default(0)
  usersWithFirstContact Int @default(0)
  
  avgDaysToFirstApply Float?
  avgDaysToFirstContact Float?
  
  appliedUsers    Int      @default(0) // Users who applied to anything
  applicationRate Float?   // % of cohort that applied
  transactionUsers Int     @default(0) // Users with completed transactions
  transactionRate Float?   // % that transacted
  repeatApplicants Int     @default(0) // Applied to >1 thing
  repeatTransactionUsers Int @default(0) // >1 transaction
  
  // ==================== LIFETIME VALUE ====================
  avgLTV          Float?   // Average lifetime value
  medianLTV       Float?
  ltvByVertical   Json?    // LTV breakdown
  totalRevenue    Float    @default(0)
  avgRevenuePerUser Float?
  
  // ==================== CHURN ANALYSIS ====================
  churnedUsers    Int      @default(0) // No activity in 90+ days
  churnRate       Float?   // % churned
  churnByMonth    Json?    // Churn rate by month after signup
  churnReasons    Json?    // From exit surveys
  
  // ==================== RETENTION DRIVERS ====================
  retentionFactors Json?   // What correlates with retention
  featureAdoptionImpact Json? // How features affect retention
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cohortDate, acquisitionChannel, userType])
  @@index([cohortDate])
  @@index([churnRate])
  @@index([retentionDay30])
}

// ===================== FEATURE ADOPTION METRICS =====================

model FeatureAdoption {
  id              String   @id @default(cuid())
  featureName     String   // e.g., "MAP_VIEW", "PHOTO_SWIPE", "SAVE_LISTING"
  featureCategory String   // "SEARCH", "ENGAGEMENT", "CONVERSION", "SOCIAL"
  date            DateTime
  
  // ==================== USAGE METRICS ====================
  totalUsers      Int      @default(0) // Users who used feature
  newUsers        Int      @default(0) // First time using feature today
  returningUsers  Int      @default(0) // Used before, using again
  totalSessions   Int      @default(0) // Sessions with feature use
  totalUsage      Int      @default(0) // Total times feature used
  avgUsagePerUser Float?   // Average times used per user
  medianUsagePerUser Int?  // Median usage count
  usageDistribution Json?  // {1: 45, 2-5: 67, 6-10: 23, 10+: 12}
  
  // ==================== ADOPTION RATES ====================
  adoptionRate    Float?   // % of active users using feature
  weeklyAdoption  Float?   // % using in last 7 days
  monthlyAdoption Float?   // % using in last 30 days
  adoptionByUserType Json? // {"PROVIDER": 0.45, "BENEFICIARY": 0.67}
  adoptionByVertical Json? // {"HOUSING": 0.56, "JOBS": 0.34}
  
  // ==================== TIME TO ADOPTION ====================
  avgDaysToFirstUse Float? // Days from signup to first use
  medianDaysToFirstUse Int?
  cumulativeAdoption Json? // % adopted by day: {7: 0.23, 30: 0.45}
  
  // ==================== IMPACT METRICS ====================
  conversionRate   Float?  // % of users who completed action after using feature
  conversionLift   Float?  // Improvement vs non-users
  sessionLengthImpact Float? // Minutes added to session
  retentionImpact  Float?   // % improvement in 30-day retention
  satisfactionScore Float? // Based on post-interaction feedback (0-5)
  feedbackCount    Int     @default(0)
  positiveFeedback Int     @default(0)
  negativeFeedback Int     @default(0)
  
  // ==================== A/B TESTING ====================
  experimentId     String?
  experimentGroup String?  // "control", "treatment_a", etc.
  experimentVariant String?
  testMetric      Float?   // Primary metric for test
  testPValue      Float?   // Statistical significance
  testWinner      Boolean? // Whether this variant won
  
  // ==================== USER FEEDBACK ====================
  featureRequests Int      @default(0) // Times users asked for this
  featureComplaints Int    @default(0) // Negative feedback specific
  feedbackThemes  Json?    // Themes in user feedback
  
  // ==================== TECHNICAL METRICS ====================
  avgLoadTime     Float?   // Milliseconds
  errorRate       Float?   // % of uses with error
  crashRate       Float?   // % of sessions with crash
  usageByPlatform Json?    // {"MOBILE": 0.78, "WEB": 0.22}
  
  // ==================== TRENDS ====================
  dailyTrend      Json?    // Last 30 days of usage
  weeklyGrowth    Float?   // Week-over-week growth
  monthlyGrowth   Float?   // Month-over-month growth
  peakUsageHour   Int?     // Hour of day with most usage
  peakUsageDay    String?  // Day of week with most usage
  
  // ==================== PREDICTIONS ====================
  projectedAdoption Float? // Projected adoption in 30 days
  saturationPoint Float?   // Estimated max adoption rate
  
  @@unique([featureName, date, experimentGroup])
  @@index([featureName, date])
  @@index([featureCategory, date])
  @@index([adoptionRate])
}

// ======================================================
// KAFKA EVENTS FROM AUTH SERVICE
// ======================================================

model AuthEventLog {
  id             String   @id @default(cuid())
  
  // Event metadata
  eventType      String   // "user.registered", "user.login.google", "user.signup.failed", etc.
  serviceSource  String   @default("auth")
  
  // User info (anonymized for analytics)
  userUuid       String?
  email          String?  // Store only for debugging, consider hashing for production
  emailHash      String?  // For unique user tracking without PII
  
