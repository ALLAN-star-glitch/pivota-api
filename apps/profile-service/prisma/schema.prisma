generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                           String                        @id @default(cuid())
  uuid                         String                        @unique @default(uuid())
  accountCode                  String                        @unique
  type                         String                        @default("INDIVIDUAL")
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  name                         String?
  isVerified                   Boolean                       @default(false)
  status                       String                        @default("ACTIVE")
  activeProfiles               Json                          @default("[]")
  userRole                     String                        @default("GeneralUser")
  verifiedFeatures             Json                          @default("[]")
  individualProfile            IndividualProfile?
  organizationProfile          OrganizationProfile?
  users                        User[]
  verifications                AccountVerification[]
  employerProfile              EmployerProfile?
  housingSeekerProfile         HousingSeekerProfile?
  intermediaryAgentProfile     IntermediaryAgentProfile?
  jobSeekerProfile             JobSeekerProfile?
  propertyOwnerProfile         PropertyOwnerProfile?
  skilledProfessionalProfile   SkilledProfessionalProfile?
  socialServiceProviderProfile SocialServiceProviderProfile?
  supportBeneficiaryProfile    SupportBeneficiaryProfile?

  @@index([type])
  @@index([status])
  @@index([isVerified])
  @@index([userRole])
}

model User {
  id                      String                   @id @default(cuid())
  uuid                    String                   @unique @default(uuid())
  email                   String                   @unique
  phone                   String?                  @unique
  roleName                String                   @default("GeneralUser")
  status                  String                   @default("ACTIVE")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  profileImage            String?
  accountUuid             String
  lastLoginAt             DateTime?
  userCode                String                   @unique
  receivedInvitations     OrganizationInvitation[] @relation("receivedInvitations")
  sentInvitations         OrganizationInvitation[] @relation("sentInvitations")
  organizationMemberships OrganizationMember[]
  account                 Account                  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([email])
}

model IndividualProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  firstName    String?
  lastName     String?
  bio          String?
  gender       String?
  dateOfBirth  DateTime?
  nationalId   String?   @unique
  profileImage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([nationalId])
}

model OrganizationProfile {
  id                 String                   @id @default(cuid())
  about              String?
  website            String?
  officialEmail      String?
  officialPhone      String?
  registrationNo     String?                  @unique
  kraPin             String?                  @unique
  physicalAddress    String?
  logo               String?
  accountUuid        String                   @unique
  createdAt          DateTime                 @default(now())
  name               String
  updatedAt          DateTime                 @updatedAt
  orgCode            String?                  @unique
  uuid               String                   @unique @default(uuid())
  verificationStatus String                   @default("PENDING")
  typeSlug           String?
  invitations        OrganizationInvitation[]
  members            OrganizationMember[]
  account            Account                  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)
  type               OrganizationType?        @relation(fields: [typeSlug], references: [slug])

  @@index([accountUuid])
  @@index([typeSlug])
  @@index([registrationNo])
  @@index([verificationStatus])
}

model OrganizationMember {
  id               String              @id @default(cuid())
  userUuid         String
  organizationUuid String
  roleName         String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  organization     OrganizationProfile @relation(fields: [organizationUuid], references: [accountUuid], onDelete: Cascade)
  user             User                @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, organizationUuid])
  @@index([organizationUuid])
  @@index([userUuid])
}

model OrganizationInvitation {
  id                 String              @id @default(cuid())
  email              String
  organizationUuid   String
  token              String              @unique
  status             String              @default("PENDING")
  roleName           String              @default("GeneralUser")
  invitedByUserUuid  String
  message            String?
  expiresAt          DateTime
  acceptedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  acceptedByUserUuid String?
  acceptedByUser     User?               @relation("receivedInvitations", fields: [acceptedByUserUuid], references: [uuid])
  invitedByUser      User                @relation("sentInvitations", fields: [invitedByUserUuid], references: [uuid])
  organization       OrganizationProfile @relation(fields: [organizationUuid], references: [accountUuid], onDelete: Cascade)

  @@unique([email, organizationUuid])
  @@index([token])
  @@index([status])
  @@index([organizationUuid])
  @@index([invitedByUserUuid])
  @@index([acceptedByUserUuid])
}

model OrganizationType {
  slug          String                @id
  label         String
  description   String?
  icon          String?
  order         Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  organizations OrganizationProfile[]

  @@map("organization_types")
}

model EmployerProfile {
  id                 String   @id @default(cuid())
  accountUuid        String   @unique
  companyName        String?
  businessName       String?
  industry           String
  companySize        String
  preferredSkills    Json     @default("[]")
  foundedYear        Int?
  description        String?
  logo               String?
  remotePolicy       String?
  isVerifiedEmployer Boolean  @default(false)
  worksWithAgents    Boolean  @default(false)
  preferredAgents    Json     @default("[]")
  isRegistered       Boolean? @default(false)
  yearsExperience    Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  account            Account  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([industry])
  @@index([isVerifiedEmployer])
  @@map("employer_profiles")
}

model JobSeekerProfile {
  id                String    @id @default(cuid())
  accountUuid       String    @unique
  headline          String
  expectedSalary    Float
  skills            Json      @default("[]")
  jobTypes          Json      @default("[]")
  isActivelySeeking Boolean   @default(false)
  industries        Json      @default("[]")
  seniorityLevel    String?
  noticePeriod      String?
  workAuthorization Json      @default("[]")
  cvUrl             String?
  cvLastUpdated     DateTime?
  portfolioImages   Json      @default("[]")
  linkedInUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  hasAgent          Boolean   @default(false)
  agentUuid         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  account           Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([isActivelySeeking])
  @@map("job_seeker_profiles")
}

model PropertyOwnerProfile {
  id                     String   @id @default(cuid())
  accountUuid            String   @unique
  companyName            String?
  businessName           String?
  preferredPropertyTypes Json     @default("[]")
  serviceAreas           Json     @default("[]")
  isProfessional         Boolean  @default(false)
  licenseNumber          String?
  yearsInBusiness        Int?
  isVerifiedOwner        Boolean  @default(false)
  usesAgent              Boolean  @default(false)
  managingAgentUuid      String?
  propertyCount          Int?
  propertyTypes          Json?    @default("[]")
  propertyPurpose        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  account                Account  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([isProfessional])
  @@index([isVerifiedOwner])
  @@map("property_owner_profiles")
}

model HousingSeekerProfile {
  id                     String    @id @default(cuid())
  accountUuid            String    @unique
  minBudget              Float
  maxBudget              Float
  preferredTypes         Json      @default("[]")
  preferredCities        Json      @default("[]")
  minBedrooms            Int       @default(0)
  maxBedrooms            Int       @default(5)
  preferredNeighborhoods Json      @default("[]")
  moveInDate             DateTime?
  leaseDuration          String?
  householdSize          Int?      @default(1)
  hasPets                Boolean?  @default(false)
  petDetails             String?
  latitude               Float?
  longitude              Float?
  searchRadiusKm         Int?      @default(10)
  hasAgent               Boolean   @default(false)
  agentUuid              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  account                Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([maxBudget])
  @@map("housing_seeker_profiles")
}

model SocialServiceProviderProfile {
  id                   String   @id @default(cuid())
  accountUuid          String   @unique
  companyName          String?
  operatingName        String?
  providerType         String
  servicesOffered      Json     @default("[]")
  serviceAreas         Json     @default("[]")
  targetBeneficiaries  Json     @default("[]")
  isVerified           Boolean  @default(false)
  verifiedBy           String?
  verificationDocument String?
  about                String?
  website              String?
  contactEmail         String?
  contactPhone         String?
  officeHours          String?
  physicalAddress      String?
  peopleServed         Int?     @default(0)
  yearEstablished      Int?
  acceptsDonations     Boolean  @default(false)
  needsVolunteers      Boolean  @default(false)
  donationInfo         String?
  volunteerNeeds       String?
  yearsExperience      Int?
  qualifications       Json?    @default("[]")
  availability         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  account              Account  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([providerType])
  @@index([isVerified])
  @@map("social_service_provider_profiles")
}

model SupportBeneficiaryProfile {
  id                   String    @id @default(cuid())
  accountUuid          String    @unique
  needs                Json      @default("[]")
  city                 String
  urgentNeeds          Json      @default("[]")
  familySize           Int?
  dependents           Int?
  householdComposition String?
  vulnerabilityFactors Json      @default("[]")
  neighborhood         String?
  latitude             Float?
  longitude            Float?
  landmark             String?
  prefersAnonymity     Boolean   @default(true)
  languagePreference   Json      @default("[]")
  consentToShare       Boolean   @default(false)
  consentGivenAt       DateTime?
  consentExpiresAt     DateTime?
  referredBy           String?
  referredByUuid       String?
  caseWorkerUuid       String?
  caseNotes            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  account              Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([city])
  @@map("support_beneficiary_profiles")
}

model SkilledProfessionalProfile {
  id                String   @id @default(cuid())
  uuid              String   @unique @default(uuid())
  accountUuid       String   @unique
  title             String
  profession        String
  specialties       Json     @default("[]")
  serviceAreas      Json     @default("[]")
  yearsExperience   Int
  licenseNumber     String?
  insuranceInfo     String?
  hourlyRate        Float?
  dailyRate         Float?
  paymentTerms      String?
  availableToday    Boolean? @default(false)
  availableWeekends Boolean? @default(true)
  emergencyService  Boolean? @default(false)
  isVerified        Boolean  @default(false)
  averageRating     Float    @default(0.0)
  totalReviews      Int      @default(0)
  completedJobs     Int      @default(0)
  completionRate    Float?
  portfolioImages   Json     @default("[]")
  portfolioVideos   Json     @default("[]")
  certifications    Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  account           Account  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([profession])
  @@index([isVerified])
  @@index([averageRating])
  @@map("skilled_professional_profiles")
}

model IntermediaryAgentProfile {
  id              String    @id @default(cuid())
  uuid            String    @unique @default(uuid())
  accountUuid     String    @unique
  agencyName      String?
  businessName    String?
  agentType       String
  specializations Json      @default("[]")
  serviceAreas    Json      @default("[]")
  licenseNumber   String
  licenseBody     String?
  yearsExperience Int?
  agencyUuid      String?
  commissionRate  Float?
  feeStructure    String?
  minimumFee      Float?
  typicalFee      String?
  isVerified      Boolean   @default(false)
  verifiedBy      String?
  verifiedAt      DateTime?
  averageRating   Float     @default(0.0)
  totalReviews    Int       @default(0)
  completedDeals  Int       @default(0)
  successRate     Float?
  about           String?
  profileImage    String?
  contactEmail    String?
  contactPhone    String?
  website         String?
  socialLinks     Json      @default("{}")
  clientTypes     Json      @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  account         Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@index([accountUuid])
  @@index([agentType])
  @@index([isVerified])
  @@index([averageRating])
  @@map("intermediary_agent_profiles")
}

model AccountVerification {
  id              String    @id @default(cuid())
  accountUuid     String
  type            String
  status          String    @default("PENDING")
  documentUrl     String?
  documentType    String?
  rejectionReason String?
  verifiedAt      DateTime?
  expiresAt       DateTime?
  verifiedBy      String?
  verifiedByUuid  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  account         Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  @@unique([accountUuid, type])
  @@index([accountUuid])
  @@index([status])
  @@index([type])
  @@map("account_verifications")
}
