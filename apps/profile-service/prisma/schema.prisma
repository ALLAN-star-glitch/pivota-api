// ==================== GENERATOR & DATASOURCE ====================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Add this to enable raw SQL for check constraints
  // url      = env("DATABASE_URL")
}

// ==================== CORE ACCOUNT (Always exists) ====================
model Account {
  id          String   @id @default(cuid())
  uuid        String   @unique @default(uuid())
  accountCode String   @unique

  // Basic Identity
  name        String?  // Individual name OR Organization name
  type        String   @default("INDIVIDUAL") // INDIVIDUAL | ORGANIZATION
  status      String   @default("ACTIVE") // ACTIVE, PENDING_PAYMENT, SUSPENDED, DEACTIVATED
  
  // User role for RBAC
  userRole    String   @default("GeneralUser")
  
  // Track which profiles this account has (stored as JSON)
  activeProfiles Json   @default("[]") // ["JOB_SEEKER", "SKILLED_PROFESSIONAL", etc.]
  
  // Verification
  isVerified  Boolean  @default(false)
  verifiedFeatures Json @default("[]") // ["IDENTITY", "BUSINESS", "PROFESSIONAL_LICENSE"]

  // Base Profiles (mutually exclusive)
  individualProfile    IndividualProfile?
  organizationProfile  OrganizationProfile?
  
  // Employment Pillar
  employerProfile      EmployerProfile?        // Hiring for jobs
  jobSeekerProfile     JobSeekerProfile?       // Looking for work
  
  // Housing Pillar
  propertyOwnerProfile PropertyOwnerProfile?   // Listing properties
  housingSeekerProfile HousingSeekerProfile?   // Looking for housing
  
  // Social Support Pillar
  socialServiceProviderProfile SocialServiceProviderProfile? // NGOs, social orgs
  supportBeneficiaryProfile    SupportBeneficiaryProfile?    // People seeking help
  
  // Cross-Pillar Professional Profiles
  skilledProfessionalProfile   SkilledProfessionalProfile?   // Trades: electricians, plumbers
  intermediaryAgentProfile     IntermediaryAgentProfile?     // Agents, brokers

  // Verifications
  verifications AccountVerification[]

  // Login credentials
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([isVerified])
  @@index([userRole])
}

// ==================== LOGIN CREDENTIALS ====================
model User {
  id          String  @id @default(cuid())
  uuid        String  @unique @default(uuid())
  email       String  @unique
  phone       String? @unique

  accountUuid String
  account     Account @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  roleName    String  @default("GeneralUser") // Maps to Account.userRole
  profileImage String?

  userCode    String  @unique  // USR-XXXXXX for user identification

  status      String   @default("ACTIVE")
  lastLoginAt DateTime?
  
  // Relations
  organizationMemberships OrganizationMember[]
  sentInvitations OrganizationInvitation[] @relation("sentInvitations")
  receivedInvitations OrganizationInvitation[] @relation("receivedInvitations")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountUuid])
  @@index([email])
}

// ==================== INDIVIDUAL PROFILE ====================
model IndividualProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  firstName    String?
  lastName     String?
  bio          String?
  gender       String?
  dateOfBirth  DateTime?
  nationalId   String?   @unique
  profileImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([nationalId])
}

// ==================== ORGANIZATION PROFILE ====================
model OrganizationProfile {
  id           String    @id @default(cuid())
  uuid         String    @unique @default(uuid())
  orgCode      String?   @unique
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  name             String
  typeSlug         String?  // Foreign key to OrganizationType
  type             OrganizationType? @relation(fields: [typeSlug], references: [slug])
  registrationNo   String? @unique
  kraPin           String? @unique
  officialEmail    String?
  officialPhone    String?
  website          String?
  about            String?
  logo             String?
  physicalAddress  String?
  
  verificationStatus String @default("PENDING")

  members OrganizationMember[]
  invitations OrganizationInvitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([typeSlug])
  @@index([registrationNo])
  @@index([verificationStatus])
}

// ==================== TEAM MANAGEMENT ====================
model OrganizationMember {
  id               String       @id @default(cuid())
  userUuid         String
  user             User         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  organizationUuid String
  organization     OrganizationProfile @relation(fields: [organizationUuid], references: [accountUuid], onDelete: Cascade)

  roleName String // "ADMIN", "MEMBER", "VIEWER", "AGENT"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userUuid, organizationUuid])
  @@index([organizationUuid])
  @@index([userUuid])
}

// ==================== ORGANIZATION INVITATIONS ====================
model OrganizationInvitation {
  id               String       @id @default(cuid())
  email            String
  token            String       @unique
  status           String       @default("PENDING") // PENDING, ACCEPTED, EXPIRED, CANCELLED
  roleName         String       @default("GeneralUser")
  message          String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  
  // Relations
  organizationUuid String
  organization     OrganizationProfile @relation(fields: [organizationUuid], references: [accountUuid], onDelete: Cascade)
  
  invitedByUserUuid String
  invitedByUser     User @relation("sentInvitations", fields: [invitedByUserUuid], references: [uuid])
  
  acceptedByUserUuid String?
  acceptedByUser     User? @relation("receivedInvitations", fields: [acceptedByUserUuid], references: [uuid])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, organizationUuid])
  @@index([token])
  @@index([status])
  @@index([organizationUuid])
  @@index([invitedByUserUuid])
  @@index([acceptedByUserUuid])
}

// Add to your schema.prisma

// ==================== ORGANIZATION TYPE LOOKUP ====================
model OrganizationType {
  slug        String   @id
  label       String
  description String?
  icon        String?
  order       Int      @default(0)
  
  organizations OrganizationProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organization_types")
}

// ==================== EMPLOYER PROFILE ====================
model EmployerProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Business name (either companyName OR businessName must be provided)
  companyName     String?  // For organizations
  businessName    String?  // For individuals
  
  // Required fields
  industry        String   // Required - NOT NULL
  companySize     String   // Required - NOT NULL - "1-10", "11-50", "51-200", "200+"
  preferredSkills Json     @default("[]") // Required to have at least one skill (enforced by app)
  
  // Optional fields
  foundedYear     Int?
  description     String?
  logo            String?
  remotePolicy    String?  // "REMOTE", "HYBRID", "ONSITE"
  
  // Verification
  isVerifiedEmployer Boolean @default(false)
  
  // If using an agent/recruiter
  worksWithAgents Boolean @default(false)
  preferredAgents Json     @default("[]")
  
  // Individual-specific fields
  isRegistered    Boolean? @default(false)
  yearsExperience Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([industry])
  @@index([isVerifiedEmployer])
  @@map("employer_profiles")
}

// ==================== JOB SEEKER PROFILE ====================
model JobSeekerProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Required fields
  headline        String   // Required
  expectedSalary  Float    // Required
  skills          Json     @default("[]") // Required to have at least one skill (enforced by app)
  jobTypes        Json     @default("[]") // Required to have at least one job type (enforced by app)
  
  // Optional fields
  isActivelySeeking Boolean @default(false)
  industries      Json     @default("[]")
  seniorityLevel  String?
  noticePeriod    String?
  workAuthorization Json   @default("[]")
  cvUrl           String?
  cvLastUpdated   DateTime?
  portfolioImages Json     @default("[]")
  linkedInUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  hasAgent        Boolean @default(false)
  agentUuid       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([isActivelySeeking])
  @@map("job_seeker_profiles")
}

// ==================== PROPERTY OWNER PROFILE ====================
model PropertyOwnerProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Business name (either companyName OR businessName must be provided)
  companyName     String?  // For organizations/property management companies
  businessName    String?  // For individuals
  
  // Required fields
  preferredPropertyTypes Json @default("[]") // Required to have at least one type (enforced by app)
  serviceAreas      Json     @default("[]") // Required to have at least one area (enforced by app)
  
  // Optional fields
  isProfessional    Boolean @default(false)
  licenseNumber     String?
  yearsInBusiness   Int?
  isVerifiedOwner   Boolean @default(false)
  usesAgent         Boolean @default(false)
  managingAgentUuid String?
  
  // Individual-specific fields
  propertyCount    Int?
  propertyTypes    Json?    @default("[]")
  propertyPurpose  String?  // "PRIMARY", "INVESTMENT", "BOTH"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([isProfessional])
  @@index([isVerifiedOwner])
  @@map("property_owner_profiles")
}

// ==================== HOUSING SEEKER PROFILE ====================
model HousingSeekerProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Required fields
  minBudget         Float    // Required
  maxBudget         Float    // Required
  preferredTypes    Json     @default("[]") // Required to have at least one type (enforced by app)
  preferredCities   Json     @default("[]") // Required to have at least one city (enforced by app)
  
  // Optional fields
  minBedrooms       Int      @default(0)
  maxBedrooms       Int      @default(5)
  preferredNeighborhoods Json @default("[]")
  moveInDate        DateTime?
  leaseDuration     String?
  householdSize     Int?     @default(1)
  hasPets           Boolean? @default(false)
  petDetails        String?
  latitude          Float?
  longitude         Float?
  searchRadiusKm    Int?     @default(10)
  hasAgent          Boolean @default(false)
  agentUuid         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([maxBudget])
  @@map("housing_seeker_profiles")
}

// ==================== SOCIAL SERVICE PROVIDER PROFILE ====================
model SocialServiceProviderProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Business name (either companyName OR operatingName must be provided)
  companyName     String?  // For organizations
  operatingName   String?  // For individuals
  
  // Required fields
  providerType      String   // Required - "NGO", "SOCIAL_ENTERPRISE", "INDIVIDUAL", etc.
  servicesOffered   Json     @default("[]") // Required to have at least one service (enforced by app)
  serviceAreas      Json     @default("[]") // Required to have at least one area (enforced by app)
  
  // Optional fields
  targetBeneficiaries Json   @default("[]")
  isVerified        Boolean @default(false)
  verifiedBy        String?
  verificationDocument String?
  about             String?
  website           String?
  contactEmail      String?
  contactPhone      String?
  officeHours       String?
  physicalAddress   String?
  peopleServed      Int?    @default(0)
  yearEstablished   Int?
  acceptsDonations  Boolean @default(false)
  needsVolunteers   Boolean @default(false)
  donationInfo      String?
  volunteerNeeds    String?
  
  // Individual-specific fields
  yearsExperience   Int?
  qualifications    Json?    @default("[]")
  availability      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([providerType])
  @@index([isVerified])
  @@map("social_service_provider_profiles")
}

// ==================== SUPPORT BENEFICIARY PROFILE ====================
model SupportBeneficiaryProfile {
  id           String    @id @default(cuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Required fields
  needs              Json     @default("[]") // Required to have at least one need (enforced by app)
  city               String   // Required - location for matching
  
  // Optional fields
  urgentNeeds        Json     @default("[]")
  familySize         Int?
  dependents         Int?
  householdComposition String?
  vulnerabilityFactors Json   @default("[]")
  neighborhood       String?
  latitude           Float?
  longitude          Float?
  landmark           String?
  prefersAnonymity   Boolean @default(true)
  languagePreference Json     @default("[]")
  consentToShare     Boolean @default(false)
  consentGivenAt     DateTime?
  consentExpiresAt   DateTime?
  referredBy         String?
  referredByUuid     String?
  caseWorkerUuid     String?
  caseNotes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([city])
  @@map("support_beneficiary_profiles")
}

// ==================== SKILLED PROFESSIONAL PROFILE ====================
model SkilledProfessionalProfile {
  id           String    @id @default(cuid())
  uuid         String    @unique @default(uuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Required fields
  title            String   // Required - e.g., "Master Electrician"
  profession       String   // Required - e.g., "ELECTRICIAN"
  specialties      Json     @default("[]") // Required to have at least one specialty (enforced by app)
  serviceAreas     Json     @default("[]") // Required to have at least one area (enforced by app)
  yearsExperience  Int      // Required
  
  // Optional fields
  licenseNumber    String?
  insuranceInfo    String?
  hourlyRate       Float?
  dailyRate        Float?
  paymentTerms     String?
  availableToday   Boolean? @default(false)
  availableWeekends Boolean? @default(true)
  emergencyService Boolean? @default(false)
  isVerified       Boolean   @default(false)
  averageRating    Float     @default(0.0)
  totalReviews     Int       @default(0)
  completedJobs    Int       @default(0)
  completionRate   Float?
  portfolioImages  Json      @default("[]")
  portfolioVideos  Json      @default("[]")
  certifications   Json      @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([profession])
  @@index([isVerified])
  @@index([averageRating])
  @@map("skilled_professional_profiles")
}

// ==================== INTERMEDIARY AGENT PROFILE ====================
model IntermediaryAgentProfile {
  id           String    @id @default(cuid())
  uuid         String    @unique @default(uuid())
  accountUuid  String    @unique
  account      Account   @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  // Business name (either agencyName OR businessName must be provided)
  agencyName       String?  // For agencies
  businessName     String?  // For individuals
  
  // Required fields
  agentType        String   // Required - "HOUSING_AGENT", "RECRUITMENT_AGENT", etc.
  specializations  Json     @default("[]") // Required to have at least one specialization (enforced by app)
  serviceAreas     Json     @default("[]") // Required to have at least one area (enforced by app)
  licenseNumber    String   // Required - Agent license/certification
  
  // Optional fields
  licenseBody      String?
  yearsExperience  Int?
  agencyUuid       String?
  commissionRate   Float?
  feeStructure     String?
  minimumFee       Float?
  typicalFee       String?
  isVerified       Boolean  @default(false)
  verifiedBy       String?
  verifiedAt       DateTime?
  averageRating    Float    @default(0.0)
  totalReviews     Int      @default(0)
  completedDeals   Int      @default(0)
  successRate      Float?
  about            String?
  profileImage     String?
  contactEmail     String?
  contactPhone     String?
  website          String?
  socialLinks      Json     @default("{}")
  clientTypes      Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountUuid])
  @@index([agentType])
  @@index([isVerified])
  @@index([averageRating])
  @@map("intermediary_agent_profiles")
}

// ==================== VERIFICATION TRACKING ====================
model AccountVerification {
  id          String   @id @default(cuid())
  accountUuid String
  account     Account  @relation(fields: [accountUuid], references: [uuid], onDelete: Cascade)

  type        String   // "IDENTITY", "BUSINESS", "PROFESSIONAL_LICENSE", "AGENT_LICENSE", "NGO_REGISTRATION", "PROPERTY_OWNER"
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED
  documentUrl String?
  documentType String? // "NATIONAL_ID", "PASSPORT", "CERTIFICATE", "LICENSE", "KRA_PIN", "REGISTRATION"
  rejectionReason String?
  verifiedAt  DateTime?
  expiresAt   DateTime?
  verifiedBy  String?  // Admin or system that verified
  verifiedByUuid String? // Reference to admin user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountUuid, type])
  @@index([accountUuid])
  @@index([status])
  @@index([type])
  @@map("account_verifications")
}