generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Credential {
  id            String    @id @default(cuid())
  uuid          String    @unique @default(uuid())
  userUuid      String    @unique
  email         String    @unique
  passwordHash  String?  
  mfaSecret     String?
  mfaEnabled    Boolean   @default(true)
  googleProviderId String? @unique
  failedAttempts Int      @default(0)
  lockoutExpires DateTime?
  lastLoginAt    DateTime? 
  passwordSetupTokens PasswordSetupToken[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // INDEXES (ADD THIS IF MISSING)
  @@index([userUuid])
  @@index([email])  // THIS IS CRITICAL FOR USER EXISTENCE CHECKS
}

model Session {
  id            String    @id @default(cuid())  // CHANGED: from Int to String with cuid()
  uuid          String    @unique @default(uuid())
  userUuid      String
  tokenId       String    @unique @default(uuid())
  hashedToken   String
  
  // Contextual Data (Already present)
  device        String?
  ipAddress     String?
  userAgent     String?
  os            String?
  
  // --- NEW RICH CLIENT INFO FIELDS ---
  deviceType    String?   // "MOBILE", "TABLET", "DESKTOP", "BOT", "UNKNOWN"
  osVersion     String?
  browser       String?
  browserVersion String?
  isMobile      Boolean?
  isTablet      Boolean?
  isDesktop     Boolean?
  isBot         Boolean?
  
  // --- RECOMMENDED ADDITION ---
  lastActiveAt  DateTime  @default(now()) // Update this on every refresh/authorized request
  
  revoked       Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime

  @@index([userUuid])
  @@index([revoked])
  @@index([expiresAt])
  @@index([tokenId])
}

model Otp {
  id            String    @id @default(cuid())
  uuid          String    @unique @default(uuid())
  email         String
  code          String   
  purpose       String    @default("SIGNUP") 
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  // ADD THIS UNIQUE CONSTRAINT
  @@unique([email, purpose])  // ← Add this line!
  
  // OPTIMIZED INDEXES FOR PERFORMANCE
  @@index([email, code])                    // For OTP verification lookups
  @@index([email, purpose])                 // For deleteMany operations
  @@index([email, purpose, createdAt])      // For rate limiting COUNT queries
  @@index([purpose])                        // For general purpose queries
  @@index([expiresAt])                      // For cleanup jobs
}

model OtpRequestLog {
  id        String   @id @default(cuid())
  email     String
  purpose   String
  createdAt DateTime @default(now())
  
  @@index([email, purpose, createdAt])
}

// ======================================================
// NEW: Password Setup Tokens for Invitation Flow
// ======================================================
model PasswordSetupToken {
  id            String    @id @default(cuid())
  uuid          String    @unique @default(uuid())
  userUuid      String
  credential    Credential @relation(fields: [userUuid], references: [userUuid], onDelete: Cascade)
  token         String    @unique
  expiresAt     DateTime
  used          Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([token])
  @@index([expiresAt])
  @@index([userUuid])
}

// ======================================================
// OPTIONAL: Track invitation events for audit
// ======================================================
model InvitationAudit {
  id                String    @id @default(cuid())
  uuid              String    @unique @default(uuid())
  email             String
  userUuid          String?   // Will be null until user accepts
  organizationUuid  String
  invitedByUserUuid String
  status            String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  acceptedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([organizationUuid])
  @@index([status])
  @@index([invitedByUserUuid])
}