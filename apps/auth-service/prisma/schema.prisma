generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Credential {
  id            String    @id @default(cuid())  // CHANGED: from Int to String with cuid()
  uuid          String    @unique @default(uuid())
  userUuid      String    @unique
  email         String    @unique
  passwordHash  String?  

  mfaSecret     String?
  mfaEnabled    Boolean   @default(true)

  // Optional: Store the Google Unique ID for extra security/linking
  googleProviderId String? @unique
  
  // Keep these here: They protect the IDENTITY regardless of the device
  failedAttempts Int      @default(0)
  lockoutExpires DateTime?
  
  // Global record of the last time this user successfully authenticated
  lastLoginAt    DateTime? 

  // Relation to password setup tokens
  passwordSetupTokens PasswordSetupToken[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userUuid])
  @@index([email])
}

model Session {
  id            String    @id @default(cuid())  // CHANGED: from Int to String with cuid()
  uuid          String    @unique @default(uuid())
  userUuid      String
  tokenId       String    @unique @default(uuid())
  hashedToken   String
  
  // Contextual Data (Already present)
  device        String?
  ipAddress     String?
  userAgent     String?
  os            String?
  
  // --- NEW RICH CLIENT INFO FIELDS ---
  deviceType    String?   // "MOBILE", "TABLET", "DESKTOP", "BOT", "UNKNOWN"
  osVersion     String?
  browser       String?
  browserVersion String?
  isMobile      Boolean?
  isTablet      Boolean?
  isDesktop     Boolean?
  isBot         Boolean?
  
  // --- RECOMMENDED ADDITION ---
  lastActiveAt  DateTime  @default(now()) // Update this on every refresh/authorized request
  
  revoked       Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime

  @@index([userUuid])
  @@index([revoked])
  @@index([expiresAt])
  @@index([tokenId])
}

model Otp {
  id            String    @id @default(cuid())
  uuid          String    @unique @default(uuid())
  email         String
  code          String   
  purpose       String    @default("SIGNUP") 
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  @@index([email, code])
  @@index([purpose])
  @@index([expiresAt])
}

// ======================================================
// NEW: Password Setup Tokens for Invitation Flow
// ======================================================
model PasswordSetupToken {
  id            String    @id @default(cuid())
  uuid          String    @unique @default(uuid())
  userUuid      String
  credential    Credential @relation(fields: [userUuid], references: [userUuid], onDelete: Cascade)
  token         String    @unique
  expiresAt     DateTime
  used          Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([token])
  @@index([expiresAt])
  @@index([userUuid])
}

// ======================================================
// OPTIONAL: Track invitation events for audit
// ======================================================
model InvitationAudit {
  id                String    @id @default(cuid())
  uuid              String    @unique @default(uuid())
  email             String
  userUuid          String?   // Will be null until user accepts
  organizationUuid  String
  invitedByUserUuid String
  status            String    @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  acceptedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([organizationUuid])
  @@index([status])
  @@index([invitedByUserUuid])
}