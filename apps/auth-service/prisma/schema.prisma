generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Credential {
  id                  String               @id @default(cuid())
  passwordHash        String?
  mfaSecret           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  userUuid            String               @unique
  email               String               @unique
  failedAttempts      Int                  @default(0)
  lastLoginAt         DateTime?
  lockoutExpires      DateTime?
  mfaEnabled          Boolean              @default(true)
  googleProviderId    String?              @unique
  uuid                String               @unique @default(uuid())
  phone               String?              @unique
  passwordSetupTokens PasswordSetupToken[]

  @@index([userUuid])
  @@index([email])
}

model Session {
  id             String    @id @default(cuid())
  tokenId        String    @unique @default(uuid())
  hashedToken    String
  device         String?
  ipAddress      String?
  userAgent      String?
  os             String?
  revoked        Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  userUuid       String
  lastActiveAt   DateTime  @default(now())
  browser        String?
  browserVersion String?
  deviceType     String?
  isBot          Boolean?
  isDesktop      Boolean?
  isMobile       Boolean?
  isTablet       Boolean?
  osVersion      String?
  uuid           String    @unique @default(uuid())

  @@index([userUuid])
  @@index([revoked])
  @@index([expiresAt])
  @@index([tokenId])
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  purpose   String   @default("SIGNUP")
  expiresAt DateTime
  createdAt DateTime @default(now())
  uuid      String   @unique @default(uuid())

  @@unique([email, purpose])
  @@index([email, code])
  @@index([email, purpose])
  @@index([email, purpose, createdAt])
  @@index([purpose])
  @@index([expiresAt])
}

model OtpRequestLog {
  id        String   @id @default(cuid())
  email     String
  purpose   String
  createdAt DateTime @default(now())

  @@index([email, purpose, createdAt])
}

model PasswordSetupToken {
  id         String     @id @default(cuid())
  userUuid   String
  token      String     @unique
  expiresAt  DateTime
  used       Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  uuid       String     @unique @default(uuid())
  credential Credential @relation(fields: [userUuid], references: [userUuid], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([userUuid])
}

model InvitationAudit {
  id                String    @id @default(cuid())
  email             String
  userUuid          String?
  organizationUuid  String
  invitedByUserUuid String
  status            String    @default("PENDING")
  acceptedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  uuid              String    @unique @default(uuid())

  @@index([email])
  @@index([organizationUuid])
  @@index([status])
  @@index([invitedByUserUuid])
}
